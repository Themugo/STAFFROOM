  apiKeys           ApiKey[]
  
  // StaffRoom Ecosystem Relations
  pluginInstallations PluginInstallation[]
  pluginReviews     PluginReview[]
  
  // Executive Command Center Relations
  executiveAlerts   ExecutiveAlert[]
  executiveInsights ExecutiveInsight[]
  
  // Phase 19: Advanced Platform Features Relations
  businessRules     BusinessRule[]
  oAuthClients      OAuthClient[]
  
  // Phase 20: Advanced Shift Management Relations
  shiftTemplates    ShiftTemplate[]
  
  // Phase 21: Duty Roster & Compensation Calendar Relations
  dutyRosters       DutyRoster[]
  compensationRules CompensationRule[]
  
  // Phase 22: Time Bank & Days Owed Relations
  timeBanks        TimeBank[]
