model TrainingRecord {
  id          String         @id @default(cuid())
  employeeId  String
  title       String
  description String?
  provider    String
  type        String?        // INTERNAL, EXTERNAL, ONLINE, WORKSHOP
  status      TrainingStatus @default(SCHEDULED)
  startDate   DateTime
  endDate     DateTime?
  location    String?
  cost        Float?
  certificateUrl String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model Asset {
  id          String      @id @default(cuid())
  employeeId  String
  name        String
  type        String      // LAPTOP, PHONE, VEHICLE, EQUIPMENT, etc.
  serialNumber String?
  model       String?
  status      AssetStatus @default(ASSIGNED)
  assignedDate DateTime
  returnDate  DateTime?
  condition   String?
  notes       String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
}

model DisciplinaryRecord {
  id          String             @id @default(cuid())
  employeeId  String
  type        DisciplinaryType
  status      DisciplinaryStatus @default(PENDING)
  date        DateTime
  description String
  severity    String             // LOW, MEDIUM, HIGH, CRITICAL
  action      String?
  actionTaken  String?
  resolvedBy  String?
  resolvedAt  DateTime?
  appealDeadline DateTime?
  appealReason String?
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([date])
}

model PromotionHistory {
  id          String       @id @default(cuid())
  employeeId  String
  type        PromotionType
  fromDate    DateTime
  toDate      DateTime?
  oldPosition String?
  newPosition String
  oldSalary   Float?
  newSalary   Float?
  reason      String
  approvedBy  String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([fromDate])
}

model SalaryHistory {
  id          String   @id @default(cuid())
  employeeId  String
  amount      Float
  currency    String   @default("KES")
  effectiveDate DateTime
  reason      String
  type        String   @default("INCREMENT") // INCREMENT, DECREMENT, BONUS, ADJUSTMENT
  approvedBy  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([effectiveDate])
}

model Dependant {
  id          String   @id @default(cuid())
  employeeId  String
  firstName   String
  lastName    String
  relationship String
  dateOfBirth DateTime?
  gender      String?
  occupation  String?
  phone       String?
  isEmergency Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([isEmergency])
