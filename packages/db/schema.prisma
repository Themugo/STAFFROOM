  @@index([tenantId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
}

model Employee {
  id                String         @id @default(cuid())
  userId            String?        @unique
  companyId         String
  branchId          String?
  
  employeeId        String         @unique
  firstName         String
  lastName          String
  email             String         @unique
  phone             String?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  country           String         @default("Kenya")
  postalCode        String?
  profileImage      String?
  
  departmentId      String
  positionId        String
  managerId         String?
  
  status            EmployeeStatus @default(ACTIVE)
  hireDate          DateTime
  terminationDate   DateTime?
  salary            Float?
  bankName          String?
  bankAccount       String?
  bankAccountName   String?
  
  emergencyContactName    String?
  emergencyContactPhone   String?
  emergencyContactRelation String?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  user              User?          @relation(fields: [userId], references: [id])
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?        @relation(fields: [branchId], references: [id])
  department        Department     @relation(fields: [departmentId], references: [id])
  position          Position       @relation(fields: [positionId], references: [id])
  manager           Employee?      @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates      Employee[]     @relation("ManagerRelation")
  headOfDepartments Department[]  @relation("DepartmentHead")
  attendances       Attendance[]
  leaves            Leave[]
  performanceReviews PerformanceReview[]
  documents         Document[]
  employmentHistory EmploymentHistory[]
  contracts         Contract[]
  certifications    Certification[]
  skills            Skill[]
  trainingRecords   TrainingRecord[]
  assets            Asset[]
  disciplinaryRecords DisciplinaryRecord[]
  promotionHistory  PromotionHistory[]
  salaryHistory     SalaryHistory[]
  dependants        Dependant[]
  
  // Payroll Relations
  payslips          Payslip[]
  
  // Leave Management Relations
  leaveBalances     LeaveBalance[]
  leaveTransactions LeaveTransaction[]
  
  // Attendance Intelligence Relations
  employeeShifts    EmployeeShift[]
  registeredDevices RegisteredDevice[]
  attendanceLocations AttendanceLocation[]
  
  // Phase 20: Advanced Shift Management Relations
  shiftAssignments   ShiftAssignment[] @relation("EmployeeShiftAssignments")
  
  // Phase 21: Duty Roster & Compensation Calendar Relations
  rosterAssignments  RosterAssignment[] @relation("EmployeeRosterAssignments")
  compensationCredits CompensationCredit[] @relation("EmployeeCompensationCredits")
  
  // Phase 22: Time Bank & Days Owed Relations
  timeBank         TimeBank[] @relation("EmployeeTimeBank")
  employeeDebts    EmployeeDebt[] @relation("EmployeeDebts")
  employeeCredits  EmployeeCredit[] @relation("EmployeeCredits")
  
  // Phase 23: Workforce Balancing & Department Hub Relations
  departmentPosts  DepartmentPost[] @relation("DepartmentPostAuthor")
  departmentComments DepartmentComment[] @relation("DepartmentCommentAuthor")
  
  // Phase 24: Shift Swap & Coverage Planning Relations
  swapRequestsAsRequester ShiftSwapRequest[] @relation("SwapRequester")
  swapRequestsAsTarget ShiftSwapRequest[] @relation("SwapTarget")
  calendarEvents   WorkforceCalendarEvent[] @relation("CalendarEventEmployee")
  
  // Phase 25: Attendance Reconciliation & Workforce Planning Relations
  attendanceReconciliations AttendanceReconciliation[] @relation("AttendanceReconciliation")
  
  // Phase 26: Governance Layer Architecture Relations
  auditLogs         AuditLog[] @relation("AuditLogPerformer")
  auditApprovals    AuditLog[] @relation("AuditLogApprover")
  liabilityRecords  LiabilityRecord[] @relation("LiabilityRecordLiable")
  attendanceVerifications AttendanceVerification[] @relation("AttendanceVerificationEmployee")
  supervisorVerifications AttendanceVerification[] @relation("AttendanceVerificationSupervisor")
  payrollReconciliations PayrollReconciliation[] @relation("PayrollReconciliationEmployee")
  payrollLocks      PayrollReconciliation[] @relation("PayrollReconciliationLockedBy")
  workforceDisputes WorkforceDispute[] @relation("WorkforceDisputeEmployee")
  disputeResolutions WorkforceDispute[] @relation("WorkforceDisputeResolver")
  auditableCommunications AuditableCommunication[] @relation("AuditableCommunicationSender")
  communicationReadReceipts CommunicationReadReceipt[] @relation("CommunicationReadReceiptEmployee")
  payrollEvidencePacks PayrollEvidencePack[] @relation("PayrollEvidencePackEmployee")
  generatedEvidencePacks PayrollEvidencePack[] @relation("PayrollEvidencePackGenerator")
  
  // Recruitment Relations
  onboarding        Onboarding[]
  managedBranches    Branch[]       @relation("BranchManager")
  
  // Workforce Intelligence Relations
  riskPredictions   EmployeeRiskPrediction[]
  
  // Performance Management Relations
  feedbacksGiven    Feedback[]      @relation("FeedbackGiven")
  feedbacksReceived Feedback[]      @relation("FeedbackReceived")
  appraisals        Appraisal[]
  promotionRecommendations PromotionRecommendation[]
  
  // Learning & Development Relations
  instructedCourses Course[]       @relation("CourseInstructor")
  enrollments       Enrollment[]
  learningPathEnrollments LearningPathEnrollment[]
  certifications    Certification[]
  employeeSkills    EmployeeSkill[]
  
  // Asset Management Relations
  assetAssignments  AssetAssignment[]
  
  // Internal Communications Relations
  authoredAnnouncements Announcement[] @relation("AnnouncementAuthor")
  readAnnouncements AnnouncementRead[]
  createdChats Chat[] @relation("ChatCreator")
  chatParticipants ChatParticipant[]
  sentMessages ChatMessage[] @relation("ChatMessageSender")
  organizedEvents Event[] @relation("EventOrganizer")
  eventRegistrations EventRegistration[]
  createdSurveys Survey[] @relation("SurveyCreator")
  surveyResponses SurveyResponse[]
  givenRecognitions Recognition[] @relation("RecognitionGiver")
  receivedRecognitions Recognition[] @relation("RecognitionRecipient")
  
  // Phase 28: High Priority Gaps - Employment Types & Contract Governance Relations
  employmentContract EmploymentContract?
  contractAmendments ContractAmendment[]
  
  // Phase 28: Compensation & Benefits Relations
  compensationComponents CompensationComponent[]
  benefitEnrollments BenefitEnrollment[]
  
  // Phase 28: Discipline & Conduct Relations
  disciplinaryRecordsPhase28 DisciplinaryRecord[]
  investigations Investigation[]
  disciplinaryHearings DisciplinaryHearing[]
  disciplinaryAppeals DisciplinaryAppeal[]
  suspensions Suspension[]
  
  // Phase 28: Grievances Relations
  grievances Grievance[]
  grievancesAsAccused Grievance[]
  grievancesAssignedTo Grievance[]
  grievancesAsMediator Grievance[]
  grievancesEscalatedTo Grievance[]
  
  // Phase 28: Occupational Health & Safety Relations
  incidents Incident[]
  medicalCases MedicalCase[]
  safetyViolations SafetyViolation[]
  reportedIncidents Incident[]
  reportedSafetyViolations SafetyViolation[]
  
  // Phase 28: Exit Management Relations
  exitProcess ExitProcess?
  clearanceItems ClearanceItem[]
  
  // Phase 28: Compliance Relations
  complianceRecords ComplianceRecord[]
  
  // Phase 28: Employee Financial Services Relations
  loans Loan[]
  loanGuarantees Loan[]
  loanRepayments LoanRepayment[]
  salaryAdvances SalaryAdvance[]
  deductions Deduction[]
  
  // Phase 28: Matrix Reporting & Acting Appointments Relations
  reportingRelationshipsAsEmployee ReportingRelationship[]
  reportingRelationshipsAsSupervisor ReportingRelationship[]
  actingAppointments ActingAppointment[]
  actingAsIncumbent ActingAppointment[]
  
  @@index([employeeId])
  @@index([email])
  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([positionId])
}

model Department {
  id                String            @id @default(cuid())
  companyId         String
  branchId          String?
  
  name              String
  code              String?
  description       String?
  location          String?
  budget            Float?
  
  // Hierarchy fields
  parentDepartmentId String?
  level             Int               @default(0)
  path              String?           // For hierarchical queries
  
  // Management
  headId            String?           // Department head employee ID
  status            DepartmentStatus  @default(ACTIVE)
  
  // Settings
  settings          Json?             // Flexible settings for department-specific rules
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?           @relation(fields: [branchId], references: [id])
  parentDepartment  Department?       @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  subDepartments    Department[]      @relation("DepartmentHierarchy")
  head              Employee?         @relation("DepartmentHead", fields: [headId], references: [id])
  employees         Employee[]
  positions         Position[]
  workflows         DepartmentWorkflow[]
  policies          DepartmentPolicy[]
  
  // Workforce Intelligence Relations
  productivityScores DepartmentProductivityScore[]
  hiringForecasts    HiringForecast[]
  salaryBenchmarks  SalaryBenchmark[]
  
  // Asset Management Relations
  assets            Asset[]
  
  // Internal Communications Relations
  chats             Chat[]
  events            Event[]
  
  // Phase 20: Advanced Shift Management Relations
  shiftTemplates    ShiftTemplate[]
  
  // Phase 21: Duty Roster & Compensation Calendar Relations
  dutyRosters       DutyRoster[]
  
  // Phase 23: Workforce Balancing & Department Hub Relations
  workforceBalances WorkforceBalance[]
  departmentPosts   DepartmentPost[]
  
  // Phase 24: Shift Swap & Coverage Planning Relations
  shiftSwapRequests ShiftSwapRequest[]
  coverageWarnings  CoverageWarning[]
  calendarEvents    WorkforceCalendarEvent[]
  
  // Phase 25: Attendance Reconciliation & Workforce Planning Relations
  workforceForecasts WorkforceForecast[]
  
  // Phase 26: Governance Layer Architecture Relations
  auditableCommunications AuditableCommunication[]
  
  // Phase 28: High Priority Gaps - Matrix Reporting Relations
  reportingRelationships ReportingRelationship[]
  clearanceItems ClearanceItem[]
  
  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([parentDepartmentId])
  @@index([level])
  @@index([status])
}

model Position {
  id           String   @id @default(cuid())
  companyId    String
  title        String
  description String?
  departmentId String
  baseSalary   Float?
  requirements String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  
  // Workforce Intelligence Relations
  salaryBenchmarks SalaryBenchmark[]
  
  @@index([companyId])
  @@index([departmentId])
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  breakStart  DateTime?
  breakEnd    DateTime?
  workHours   Float?
  isLate      Boolean  @default(false)
  notes       String?
  location    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model Leave {
  id          String     @id @default(cuid())
  employeeId  String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String
  status      LeaveStatus @default(PENDING)
  rejectionReason String?
  
  approvedBy  String?
  approvedAt  DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model PerformanceReview {
  id          String   @id @default(cuid())
  employeeId  String
  reviewerId  String
  period      String
  rating      Float
  strengths   String?
  weaknesses  String?
  goals       String?
  comments    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([period])
}

model Document {
  id          String   @id @default(cuid())
  employeeId  String
  title       String
  type        String
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  
  uploadedBy  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([type])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  changes     String?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model DepartmentWorkflow {
  id          String         @id @default(cuid())
  departmentId String
  name        String
  description String?
  entityType  String         // LEAVE, EXPENSE, PROMOTION, etc.
  status      WorkflowStatus @default(DRAFT)
  version     Int            @default(1)
  
  // Workflow configuration
  config      Json           // Steps, conditions, rules
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  department  Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  
  @@index([departmentId])
  @@index([entityType])
  @@index([status])
}

model WorkflowStep {
  id          String           @id @default(cuid())
  workflowId  String
  name        String
  description String?
  type        WorkflowStepType
  order       Int
  
  // Step configuration
  config      Json             // Approvers, conditions, actions
  isRequired  Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  workflow    DepartmentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  @@index([workflowId])
  @@index([order])
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  workflowId  String
  entityId    String   // ID of the entity being processed
  entityType  String
  status      WorkflowStatus @default(DRAFT)
  currentStep Int      @default(0)
  
  // Execution data
  data        Json     // Form data, request details
  result      Json?    // Final result
  
  initiatedBy String
  completedAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  workflow    DepartmentWorkflow @relation(fields: [workflowId], references: [id])
  approvals   WorkflowApproval[]
  
  @@index([workflowId])
  @@index([entityId])
  @@index([status])
}

model WorkflowApproval {
  id          String   @id @default(cuid())
  executionId String
  stepId      String
  approverId  String
  status      String   // PENDING, APPROVED, REJECTED
  comments    String?
  
  approvedAt  DateTime?
  rejectedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId])
  @@index([approverId])
  @@index([status])
}

model DepartmentPolicy {
  id          String   @id @default(cuid())
  departmentId String
  name        String
  description String?
  type        String   // LEAVE_POLICY, WORK_HOURS, DRESS_CODE, etc.
  content     Json     // Policy details, rules
  
  isActive    Boolean  @default(true)
  effectiveFrom DateTime
  effectiveTo DateTime?
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  @@index([departmentId])
  @@index([type])
  @@index([isActive])
}

