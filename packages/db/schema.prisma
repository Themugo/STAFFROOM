  period      String
  
  grossSalary Float
  netSalary   Float
  totalTax    Float
  totalDeductions Float
  
  earnings    Json        // Breakdown of earnings
  deductions  Json        // Breakdown of deductions
  taxDetails  Json        // Tax breakdown (PAYE, NHIF, NSSF)
  
  generatedAt DateTime
  pdfUrl      String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRun  PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([payrollRunId])
  @@index([period])
}

// Leave Management 2.0 Models

model LeaveBalance {
  id          String           @id @default(cuid())
  employeeId  String
  leaveType   LeaveType
  year        Int
  balance     Float            @default(0)
  used        Float            @default(0)
  carriedForward Float         @default(0)
  
  accrualRate Float?           // Days per month/year
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, leaveType, year])
  @@index([employeeId])
  @@index([leaveType])
}

model LeaveAccrualRule {
  id          String           @id @default(cuid())
  leaveType   LeaveType
  accrualType LeaveAccrualType
  rate        Float            // Days per period
  maxBalance  Float?           // Maximum balance allowed
  carryForwardPercentage Float? // Percentage that can be carried forward
  expiryMonths Int?            // Months after which carried leave expires
  
  isActive    Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  @@index([leaveType])
  @@index([isActive])
}

model PublicHoliday {
