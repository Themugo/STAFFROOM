  name        String
  type        ShiftType
  startTime   DateTime
  endTime     DateTime
  breakDuration Int?     // In minutes
  location    String?
  
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([type])
  @@index([isActive])
}

model EmployeeShift {
