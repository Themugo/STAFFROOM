generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR_MANAGER
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  COMPASSIONATE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowStepType {
  APPROVAL
  NOTIFICATION
  CONDITIONAL
  AUTOMATIC
}

enum ContractType {
  PERMANENT
  CONTRACT
  INTERNSHIP
  PROBATION
  PART_TIME
  CONSULTANT
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
  PENDING
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum TrainingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  ASSIGNED
  RETURNED
  DAMAGED
  LOST
  MAINTENANCE
}

enum DisciplinaryType {
  WARNING
  SUSPENSION
  PROBATION
  TERMINATION
}

enum DisciplinaryStatus {
  PENDING
  ACTIVE
  RESOLVED
  APPEALED
}

enum PromotionType {
  PROMOTION
  DEMOTION
  LATERAL_MOVE
  TITLE_CHANGE
}

// Payroll & Compliance Enums
enum PayrollStatus {
  DRAFT
  CALCULATED
  PENDING_APPROVAL
  APPROVED
  PROCESSED
  PAID
  CANCELLED
}

enum SalaryComponentType {
  BASIC
  ALLOWANCE
  OVERTIME
  BONUS
  COMMISSION
  DEDUCTION
  TAX
  BENEFIT
}

enum DeductionType {
  TAX
  NHIF
  NSSF
  PENSION
  LOAN
  ADVANCE
  INSURANCE
  OTHER
}

enum PayrollFrequency {
  MONTHLY
  BI_WEEKLY
  WEEKLY
  DAILY
}

// Leave Management 2.0 Enums
enum LeaveAccrualType {
  MONTHLY
  QUARTERLY
  ANNUAL
  MANUAL
}

enum LeaveBalanceType {
  CREDIT
  DEBIT
  ADJUSTMENT
  CARRY_FORWARD
}

// Attendance Intelligence Enums
enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  ROTATING
  FLEXIBLE
}

enum AttendanceMethod {
  GPS
  IP_RESTRICTED
  BIOMETRIC
  MANUAL
  QR_CODE
  NFC
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  LOST
}

// Recruitment Module Enums
enum VacancyStatus {
  DRAFT
  OPEN
  CLOSED
  ON_HOLD
  FILLED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  OFFER_EXTENDED
  OFFER_ACCEPTED
  OFFER_DECLINED
  REJECTED
  HIRED
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

// Universal Workflow Engine Enums
enum WorkflowCategory {
  LEAVE
  PROCUREMENT
  RECRUITMENT
  EXPENSE
  APPROVAL
  CUSTOM
}

enum WorkflowTriggerType {
  MANUAL
  AUTOMATIC
  SCHEDULED
  EVENT_BASED
}

enum StepType {
  APPROVAL
  NOTIFICATION
  TASK
  CONDITION
  PARALLEL
  SEQUENTIAL
  TIMER
  WEBHOOK
  EMAIL
  SMS
  SYSTEM_ACTION
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
  CANCELLED
}

enum ExecutionStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
  ON_HOLD
}

// Enterprise Security Enums
enum MFAType {
  SMS
  EMAIL
  TOTP
  AUTHENTICATOR_APP
}

enum MFAStatus {
  ENABLED
  DISABLED
  PENDING_SETUP
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  TERMINATED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXPORT
  IMPORT
  CONFIGURE
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum PermissionScope {
  GLOBAL
  DEPARTMENT
  TEAM
  PERSONAL
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  role              Role     @default(EMPLOYEE)
  isActive          Boolean  @default(true)
  emailVerified     DateTime?
  passwordResetToken String?
  passwordResetExpires DateTime?
  lastLogin         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  tenantId          String?
  
  employee          Employee?
  sessions          Session[]
  auditLogs         AuditLog[]
  refreshTokens      RefreshToken[]
  multiFactorAuth   MultiFactorAuth?
  loginHistory       LoginHistory[]
  deviceSessions    DeviceSession[]
  
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])
  
  @@index([email])
  @@index([tenantId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
}

model Employee {
  id                String         @id @default(cuid())
  userId            String?        @unique
  employeeId        String         @unique
  firstName         String
  lastName          String
  email             String         @unique
  phone             String?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  country           String         @default("Kenya")
  postalCode        String?
  profileImage      String?
  
  departmentId      String
  positionId        String
  managerId         String?
  
  status            EmployeeStatus @default(ACTIVE)
  hireDate          DateTime
  terminationDate   DateTime?
  salary            Float?
  bankName          String?
  bankAccount       String?
  bankAccountName   String?
  
  emergencyContactName    String?
  emergencyContactPhone   String?
  emergencyContactRelation String?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  user              User?          @relation(fields: [userId], references: [id])
  department        Department     @relation(fields: [departmentId], references: [id])
  position          Position       @relation(fields: [positionId], references: [id])
  manager           Employee?      @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates      Employee[]     @relation("ManagerRelation")
  headOfDepartments Department[]  @relation("DepartmentHead")
  attendances       Attendance[]
  leaves            Leave[]
  performanceReviews PerformanceReview[]
  documents         Document[]
  employmentHistory EmploymentHistory[]
  contracts         Contract[]
  certifications    Certification[]
  skills            Skill[]
  trainingRecords   TrainingRecord[]
  assets            Asset[]
  disciplinaryRecords DisciplinaryRecord[]
  promotionHistory  PromotionHistory[]
  salaryHistory     SalaryHistory[]
  dependants        Dependant[]
  
  // Payroll Relations
  payslips          Payslip[]
  
  // Leave Management Relations
  leaveBalances     LeaveBalance[]
  leaveTransactions LeaveTransaction[]
  
  // Attendance Intelligence Relations
  employeeShifts    EmployeeShift[]
  registeredDevices RegisteredDevice[]
  attendanceLocations AttendanceLocation[]
  
  // Recruitment Relations
  onboarding        Onboarding[]
  
  @@index([employeeId])
  @@index([email])
  @@index([departmentId])
  @@index([positionId])
}

model Department {
  id                String            @id @default(cuid())
  name              String            @unique
  code              String?           @unique
  description       String?
  location          String?
  budget            Float?
  
  // Hierarchy fields
  parentDepartmentId String?
  level             Int               @default(0)
  path              String?           // For hierarchical queries
  
  // Management
  headId            String?           // Department head employee ID
  status            DepartmentStatus  @default(ACTIVE)
  
  // Settings
  settings          Json?             // Flexible settings for department-specific rules
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  parentDepartment  Department?       @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  subDepartments    Department[]      @relation("DepartmentHierarchy")
  head              Employee?         @relation("DepartmentHead", fields: [headId], references: [id])
  employees         Employee[]
  positions         Position[]
  workflows         DepartmentWorkflow[]
  policies          DepartmentPolicy[]
  
  @@index([name])
  @@index([parentDepartmentId])
  @@index([level])
  @@index([status])
}

model Position {
  id           String   @id @default(cuid())
  title        String
  description String?
  departmentId String
  baseSalary   Float?
  requirements String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  
  @@index([departmentId])
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  breakStart  DateTime?
  breakEnd    DateTime?
  workHours   Float?
  isLate      Boolean  @default(false)
  notes       String?
  location    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model Leave {
  id          String     @id @default(cuid())
  employeeId  String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String
  status      LeaveStatus @default(PENDING)
  rejectionReason String?
  
  approvedBy  String?
  approvedAt  DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model PerformanceReview {
  id          String   @id @default(cuid())
  employeeId  String
  reviewerId  String
  period      String
  rating      Float
  strengths   String?
  weaknesses  String?
  goals       String?
  comments    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([period])
}

model Document {
  id          String   @id @default(cuid())
  employeeId  String
  title       String
  type        String
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  
  uploadedBy  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([type])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  changes     String?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model DepartmentWorkflow {
  id          String         @id @default(cuid())
  departmentId String
  name        String
  description String?
  entityType  String         // LEAVE, EXPENSE, PROMOTION, etc.
  status      WorkflowStatus @default(DRAFT)
  version     Int            @default(1)
  
  // Workflow configuration
  config      Json           // Steps, conditions, rules
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  department  Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  
  @@index([departmentId])
  @@index([entityType])
  @@index([status])
}

model WorkflowStep {
  id          String           @id @default(cuid())
  workflowId  String
  name        String
  description String?
  type        WorkflowStepType
  order       Int
  
  // Step configuration
  config      Json             // Approvers, conditions, actions
  isRequired  Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  workflow    DepartmentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  @@index([workflowId])
  @@index([order])
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  workflowId  String
  entityId    String   // ID of the entity being processed
  entityType  String
  status      WorkflowStatus @default(DRAFT)
  currentStep Int      @default(0)
  
  // Execution data
  data        Json     // Form data, request details
  result      Json?    // Final result
  
  initiatedBy String
  completedAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  workflow    DepartmentWorkflow @relation(fields: [workflowId], references: [id])
  approvals   WorkflowApproval[]
  
  @@index([workflowId])
  @@index([entityId])
  @@index([status])
}

model WorkflowApproval {
  id          String   @id @default(cuid())
  executionId String
  stepId      String
  approverId  String
  status      String   // PENDING, APPROVED, REJECTED
  comments    String?
  
  approvedAt  DateTime?
  rejectedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId])
  @@index([approverId])
  @@index([status])
}

model DepartmentPolicy {
  id          String   @id @default(cuid())
  departmentId String
  name        String
  description String?
  type        String   // LEAVE_POLICY, WORK_HOURS, DRESS_CODE, etc.
  content     Json     // Policy details, rules
  
  isActive    Boolean  @default(true)
  effectiveFrom DateTime
  effectiveTo DateTime?
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  @@index([departmentId])
  @@index([type])
  @@index([isActive])
}

// Employee 360 Profile Models

model EmploymentHistory {
  id          String   @id @default(cuid())
  employeeId  String
  company     String
  position    String
  department  String?
  startDate   DateTime
  endDate     DateTime?
  description String?
  reasonForLeaving String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([startDate])
}

model Contract {
  id          String         @id @default(cuid())
  employeeId  String
  type        ContractType
  status      ContractStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime?
  salary      Float?
  benefits    Json?          // Benefits package details
  terms       Json?          // Contract terms and conditions
  documentUrl String?
  
  signedBy    String?
  signedAt    DateTime?
  approvedBy  String?
  approvedAt  DateTime?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model Certification {
  id          String   @id @default(cuid())
  employeeId  String
  name        String
  issuingBody String
  certificateNumber String?
  issueDate   DateTime
  expiryDate  DateTime?
  documentUrl String?
  status      String   @default("VALID") // VALID, EXPIRED, REVOKED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([expiryDate])
}

model Skill {
  id          String     @id @default(cuid())
  employeeId  String
  name        String
  category    String?   // Technical, Soft Skills, Language, etc.
  level       SkillLevel @default(BEGINNER)
  yearsOfExperience Float?
  verified    Boolean   @default(false)
  verifiedBy  String?
  verifiedAt  DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([category])
}

model TrainingRecord {
  id          String         @id @default(cuid())
  employeeId  String
  title       String
  description String?
  provider    String
  type        String?        // INTERNAL, EXTERNAL, ONLINE, WORKSHOP
  status      TrainingStatus @default(SCHEDULED)
  startDate   DateTime
  endDate     DateTime?
  location    String?
  cost        Float?
  certificateUrl String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model Asset {
  id          String      @id @default(cuid())
  employeeId  String
  name        String
  type        String      // LAPTOP, PHONE, VEHICLE, EQUIPMENT, etc.
  serialNumber String?
  model       String?
  status      AssetStatus @default(ASSIGNED)
  assignedDate DateTime
  returnDate  DateTime?
  condition   String?
  notes       String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
}

model DisciplinaryRecord {
  id          String             @id @default(cuid())
  employeeId  String
  type        DisciplinaryType
  status      DisciplinaryStatus @default(PENDING)
  date        DateTime
  description String
  severity    String             // LOW, MEDIUM, HIGH, CRITICAL
  action      String?
  actionTaken  String?
  resolvedBy  String?
  resolvedAt  DateTime?
  appealDeadline DateTime?
  appealReason String?
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([date])
}

model PromotionHistory {
  id          String       @id @default(cuid())
  employeeId  String
  type        PromotionType
  fromDate    DateTime
  toDate      DateTime?
  oldPosition String?
  newPosition String
  oldSalary   Float?
  newSalary   Float?
  reason      String
  approvedBy  String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([fromDate])
}

model SalaryHistory {
  id          String   @id @default(cuid())
  employeeId  String
  amount      Float
  currency    String   @default("KES")
  effectiveDate DateTime
  reason      String
  type        String   @default("INCREMENT") // INCREMENT, DECREMENT, BONUS, ADJUSTMENT
  approvedBy  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([effectiveDate])
}

model Dependant {
  id          String   @id @default(cuid())
  employeeId  String
  firstName   String
  lastName    String
  relationship String
  dateOfBirth DateTime?
  gender      String?
  occupation  String?
  phone       String?
  isEmergency Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([isEmergency])
}

// Payroll & Compliance Engine Models

model PayrollRun {
  id          String          @id @default(cuid())
  name        String
  period      String         // e.g., "January 2024"
  startDate   DateTime
  endDate     DateTime
  status      PayrollStatus   @default(DRAFT)
  frequency   PayrollFrequency @default(MONTHLY)
  
  totalGross  Float?
  totalNet    Float?
  totalTax    Float?
  totalDeductions Float?
  
  processedBy String?
  approvedBy  String?
  approvedAt  DateTime?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  payslips    Payslip[]
  
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model SalaryComponent {
  id          String            @id @default(cuid())
  name        String
  type        SalaryComponentType
  amount      Float
  isPercentage Boolean           @default(false)
  description String?
  isActive    Boolean           @default(true)
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  @@index([type])
  @@index([isActive])
}

model Deduction {
  id          String        @id @default(cuid())
  name        String
  type        DeductionType
  amount      Float
  isPercentage Boolean       @default(false)
  description String?
  isActive    Boolean       @default(true)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([type])
  @@index([isActive])
}

model Payslip {
  id          String      @id @default(cuid())
  employeeId  String
  payrollRunId String
  period      String
  
  grossSalary Float
  netSalary   Float
  totalTax    Float
  totalDeductions Float
  
  earnings    Json        // Breakdown of earnings
  deductions  Json        // Breakdown of deductions
  taxDetails  Json        // Tax breakdown (PAYE, NHIF, NSSF)
  
  generatedAt DateTime
  pdfUrl      String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRun  PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([payrollRunId])
  @@index([period])
}

// Leave Management 2.0 Models

model LeaveBalance {
  id          String           @id @default(cuid())
  employeeId  String
  leaveType   LeaveType
  year        Int
  balance     Float            @default(0)
  used        Float            @default(0)
  carriedForward Float         @default(0)
  
  accrualRate Float?           // Days per month/year
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, leaveType, year])
  @@index([employeeId])
  @@index([leaveType])
}

model LeaveAccrualRule {
  id          String           @id @default(cuid())
  leaveType   LeaveType
  accrualType LeaveAccrualType
  rate        Float            // Days per period
  maxBalance  Float?           // Maximum balance allowed
  carryForwardPercentage Float? // Percentage that can be carried forward
  expiryMonths Int?            // Months after which carried leave expires
  
  isActive    Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  @@index([leaveType])
  @@index([isActive])
}

model PublicHoliday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  isRecurring Boolean  @default(false)
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([date])
  @@index([isRecurring])
}

model LeaveTransaction {
  id          String          @id @default(cuid())
  employeeId  String
  leaveBalanceId String
  type        LeaveBalanceType
  amount      Float
  description String?
  referenceId String?         // Leave request ID
  
  createdAt   DateTime        @default(now())
  
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveBalance LeaveBalance @relation(fields: [leaveBalanceId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([leaveBalanceId])
  @@index([type])
}

// Attendance Intelligence Models

model ShiftSchedule {
  id          String    @id @default(cuid())
  name        String
  type        ShiftType
  startTime   DateTime
  endTime     DateTime
  breakDuration Int?     // In minutes
  location    String?
  
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([type])
  @@index([isActive])
}

model EmployeeShift {
  id          String        @id @default(cuid())
  employeeId  String
  shiftId     String
  effectiveDate DateTime
  endDate     DateTime?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift       ShiftSchedule @relation(fields: [shiftId], references: [id])
  
  @@index([employeeId])
  @@index([effectiveDate])
}

model AttendanceRule {
  id          String   @id @default(cuid())
  name        String
  type        String   // LATE_ARRIVAL, EARLY_DEPARTURE, ABSENCE, OVERTIME
  condition   Json     // Rules and conditions
  action      String   // What happens when rule is triggered
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([isActive])
}

model RegisteredDevice {
  id          String         @id @default(cuid())
  employeeId  String
  deviceId    String
  deviceName  String
  deviceType  String         // MOBILE, TABLET, DESKTOP, BIOMETRIC
  status      DeviceStatus   @default(ACTIVE)
  
  lastUsed    DateTime?
  ipAddress   String?
  location    Json?          // GPS coordinates
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([deviceId])
  @@index([status])
}

model AttendanceLocation {
  id          String   @id @default(cuid())
  employeeId  String
  latitude    Float
  longitude   Float
  accuracy    Float?
  timestamp   DateTime
  method      AttendanceMethod
  
  createdAt   DateTime @default(now())
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([timestamp])
}

// Recruitment Module Models

model Vacancy {
  id          String        @id @default(cuid())
  title       String
  description String
  departmentId String
  positionId  String
  location    String?
  employmentType String     // FULL_TIME, PART_TIME, CONTRACT, INTERNSHIP
  salaryMin   Float?
  salaryMax   Float?
  requirements String?
  responsibilities String?
  benefits    String?
  status      VacancyStatus @default(DRAFT)
  publishedAt DateTime?
  deadline    DateTime?
  positions   Int           @default(1)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  department  Department    @relation(fields: [departmentId], references: [id])
  position    Position      @relation(fields: [positionId], references: [id])
  applications Application[]
  
  @@index([departmentId])
  @@index([status])
  @@index([deadline])
}

model Candidate {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  location    String?
  resumeUrl   String?
  linkedInUrl String?
  portfolioUrl String?
  notes       String?
  
  source      String?  // REFERRAL, LINKEDIN, JOB_BOARD, WEBSITE, OTHER
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  applications Application[]
  
  @@index([email])
  @@index([source])
}

model Application {
  id          String            @id @default(cuid())
  vacancyId   String
  candidateId String
  status      ApplicationStatus @default(APPLIED)
  
  coverLetter String?
  expectedSalary Float?
  availableDate DateTime?
  
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  vacancy     Vacancy           @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviews  Interview[]
  
  @@unique([vacancyId, candidateId])
  @@index([vacancyId])
  @@index([candidateId])
  @@index([status])
}

model Interview {
  id          String          @id @default(cuid())
  applicationId String
  type        String          // PHONE, VIDEO, IN_PERSON, TECHNICAL
  status      InterviewStatus @default(SCHEDULED)
  
  scheduledDate DateTime
  duration    Int?            // In minutes
  location    String?
  notes       String?
  feedback    String?
  rating      Float?          // 1-5 scale
  
  interviewerId String?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  application Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  @@index([applicationId])
  @@index([status])
  @@index([scheduledDate])
}

model Onboarding {
  id          String          @id @default(cuid())
  employeeId  String
  status      OnboardingStatus @default(PENDING)
  
  startDate   DateTime
  endDate     DateTime?
  
  tasks       Json            // Onboarding checklist
  completedTasks Json?
  
  mentorId    String?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
}

// Universal Workflow Engine Models

model WorkflowTemplate {
  id          String            @id @default(cuid())
  name        String
  description String?
  category    WorkflowCategory
  version     Int               @default(1)
  isActive    Boolean           @default(true)
  
  triggerType WorkflowTriggerType @default(MANUAL)
  triggerConfig Json?           // Trigger configuration
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  
  @@index([category])
  @@index([isActive])
  @@index([version])
}

model WorkflowStep {
  id          String          @id @default(cuid())
  templateId  String
  name        String
  description String?
  type        StepType
  order       Int
  
  config      Json            // Step configuration (approval rules, conditions, etc.)
  
  isRequired  Boolean         @default(true)
  canSkip     Boolean         @default(false)
  
  timeoutMinutes Int?         // Timeout for this step
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  template    WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  executions  WorkflowStepExecution[]
  
  @@index([templateId])
  @@index([order])
  @@index([type])
}

model WorkflowExecution {
  id          String            @id @default(cuid())
  templateId  String
  category    WorkflowCategory
  
  status      ExecutionStatus   @default(STARTED)
  
  initiatedBy String
  entityId    String?           // Reference to the entity (leaveId, expenseId, etc.)
  entityType  String?           // Type of entity (LEAVE, EXPENSE, etc.)
  
  currentStep Int               @default(0)
  totalSteps  Int
  
  metadata    Json             // Additional execution data
  result      Json?            // Final result
  
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  template    WorkflowTemplate @relation(fields: [templateId], references: [id])
  stepExecutions WorkflowStepExecution[]
  approvals   WorkflowApproval[]
  
  @@index([templateId])
  @@index([category])
  @@index([status])
  @@index([entityId])
  @@index([initiatedBy])
}

model WorkflowStepExecution {
  id          String      @id @default(cuid())
  executionId String
  stepId      String
  
  status      StepStatus @default(PENDING)
  
  assignedTo  String?    // User or role assigned to this step
  assignedType String?   // USER or ROLE
  
  startedAt   DateTime?
  completedAt DateTime?
  
  metadata    Json        // Step-specific data
  result      Json?       // Step result
  
  comments    String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step        WorkflowStep @relation(fields: [stepId], references: [id])
  
  @@index([executionId])
  @@index([stepId])
  @@index([status])
  @@index([assignedTo])
}

model WorkflowApproval {
  id          String      @id @default(cuid())
  executionId String
  stepExecutionId String?
  
  approverId  String
  status      String      // APPROVED, REJECTED, PENDING
  
  comments    String?
  
  approvedAt  DateTime?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId])
  @@index([approverId])
  @@index([status])
}

// Enterprise Security Models

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model MultiFactorAuth {
  id          String    @id @default(cuid())
  userId      String
  type        MFAType
  secret      String?   // For TOTP
  phoneNumber String?   // For SMS
  email       String?   // For Email
  status      MFAStatus @default(DISABLED)
  
  backupCodes Json?     // Backup codes for recovery
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
}

model LoginHistory {
  id          String    @id @default(cuid())
  userId      String
  
  ipAddress   String?
  userAgent   String?
  deviceType  String?
  browser     String?
  os          String?
  
  loginTime   DateTime  @default(now())
  logoutTime  DateTime?
  status      String    // SUCCESS, FAILED, BLOCKED
  failureReason String?
  
  location    Json?     // { city, country, latitude, longitude }
  
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([loginTime])
  @@index([status])
}

model DeviceSession {
  id          String        @id @default(cuid())
  userId      String
  
  deviceName  String
  deviceType  String        // MOBILE, TABLET, DESKTOP
  deviceFingerprint String  // Unique device identifier
  
  ipAddress   String?
  userAgent   String?
  
  lastActive  DateTime      @default(now())
  expiresAt   DateTime
  status      SessionStatus @default(ACTIVE)
  
  isTrusted   Boolean       @default(false)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([deviceFingerprint])
  @@index([status])
  @@index([expiresAt])
}

model AuditLog {
  id          String        @id @default(cuid())
  userId      String?
  
  action      AuditAction
  severity    AuditSeverity @default(INFO)
  
  entityType  String        // User, Employee, Department, etc.
  entityId    String?
  
  description String
  metadata    Json?         // Additional context
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime      @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Permission {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  
  resource    String        // employees, departments, payroll, etc.
  action      String        // create, read, update, delete
  
  scope       PermissionScope @default(GLOBAL)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  rolePermissions RolePermission[]
  
  @@index([resource])
  @@index([action])
  @@index([scope])
}

model RolePermission {
  id          String    @id @default(cuid())
  roleId      String
  permissionId String
  
  createdAt   DateTime  @default(now())
  
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model Tenant {
  id          String    @id @default(cuid())
  name        String
  domain      String    @unique
  subdomain   String?   @unique
  
  isActive    Boolean   @default(true)
  
  encryptionKey String?  // For data encryption at rest
  
  settings    Json?     // Tenant-specific settings
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  users       User[]
  
  @@index([domain])
  @@index([subdomain])
  @@index([isActive])
}
