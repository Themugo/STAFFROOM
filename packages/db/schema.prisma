// Payroll & Compliance Engine Models

model PayrollRun {
  id          String          @id @default(cuid())
  name        String
  period      String         // e.g., "January 2024"
  startDate   DateTime
  endDate     DateTime
  status      PayrollStatus   @default(DRAFT)
  frequency   PayrollFrequency @default(MONTHLY)
  
  totalGross  Float?
  totalNet    Float?
  totalTax    Float?
  totalDeductions Float?
  
  processedBy String?
  approvedBy  String?
  approvedAt  DateTime?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  payslips    Payslip[]
  
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model SalaryComponent {
  id          String            @id @default(cuid())
  name        String
  type        SalaryComponentType
  amount      Float
  isPercentage Boolean           @default(false)
  description String?
  isActive    Boolean           @default(true)
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  @@index([type])
  @@index([isActive])
}

model Deduction {
  id          String        @id @default(cuid())
  name        String
  type        DeductionType
  amount      Float
  isPercentage Boolean       @default(false)
  description String?
  isActive    Boolean       @default(true)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([type])
  @@index([isActive])
}

model Payslip {
  id          String      @id @default(cuid())
