generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR_MANAGER
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  COMPASSIONATE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowStepType {
  APPROVAL
  NOTIFICATION
  CONDITIONAL
  AUTOMATIC
}

enum ContractType {
  PERMANENT
  CONTRACT
  INTERNSHIP
  PROBATION
  PART_TIME
  CONSULTANT
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
  PENDING
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum TrainingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  ASSIGNED
  RETURNED
  DAMAGED
  LOST
  MAINTENANCE
}

enum DisciplinaryType {
  WARNING
  SUSPENSION
  PROBATION
  TERMINATION
}

enum DisciplinaryStatus {
  PENDING
  ACTIVE
  RESOLVED
  APPEALED
}

enum PromotionType {
  PROMOTION
  DEMOTION
  LATERAL_MOVE
  TITLE_CHANGE
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  role              Role     @default(EMPLOYEE)
  isActive          Boolean  @default(true)
  emailVerified     DateTime?
  passwordResetToken String?
  passwordResetExpires DateTime?
  lastLogin         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  employee          Employee?
  sessions          Session[]
  auditLogs         AuditLog[]
  
  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
}

model Employee {
  id                String         @id @default(cuid())
  userId            String?        @unique
  employeeId        String         @unique
  firstName         String
  lastName          String
  email             String         @unique
  phone             String?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  country           String         @default("Kenya")
  postalCode        String?
  profileImage      String?
  
  departmentId      String
  positionId        String
  managerId         String?
  
  status            EmployeeStatus @default(ACTIVE)
  hireDate          DateTime
  terminationDate   DateTime?
  salary            Float?
  bankName          String?
  bankAccount       String?
  bankAccountName   String?
  
  emergencyContactName    String?
  emergencyContactPhone   String?
  emergencyContactRelation String?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  user              User?          @relation(fields: [userId], references: [id])
  department        Department     @relation(fields: [departmentId], references: [id])
  position          Position       @relation(fields: [positionId], references: [id])
  manager           Employee?      @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates      Employee[]     @relation("ManagerRelation")
  headOfDepartments Department[]  @relation("DepartmentHead")
  attendances       Attendance[]
  leaves            Leave[]
  performanceReviews PerformanceReview[]
  documents         Document[]
  employmentHistory EmploymentHistory[]
  contracts         Contract[]
  certifications    Certification[]
  skills            Skill[]
  trainingRecords   TrainingRecord[]
  assets            Asset[]
  disciplinaryRecords DisciplinaryRecord[]
  promotionHistory  PromotionHistory[]
  salaryHistory     SalaryHistory[]
  dependants        Dependant[]
  
  @@index([employeeId])
  @@index([email])
  @@index([departmentId])
  @@index([positionId])
}

model Department {
  id                String            @id @default(cuid())
  name              String            @unique
  code              String?           @unique
  description       String?
  location          String?
  budget            Float?
  
  // Hierarchy fields
  parentDepartmentId String?
  level             Int               @default(0)
  path              String?           // For hierarchical queries
  
  // Management
  headId            String?           // Department head employee ID
  status            DepartmentStatus  @default(ACTIVE)
  
  // Settings
  settings          Json?             // Flexible settings for department-specific rules
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  parentDepartment  Department?       @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  subDepartments    Department[]      @relation("DepartmentHierarchy")
  head              Employee?         @relation("DepartmentHead", fields: [headId], references: [id])
  employees         Employee[]
  positions         Position[]
  workflows         DepartmentWorkflow[]
  policies          DepartmentPolicy[]
  
  @@index([name])
  @@index([parentDepartmentId])
  @@index([level])
  @@index([status])
}

model Position {
  id           String   @id @default(cuid())
  title        String
  description String?
  departmentId String
  baseSalary   Float?
  requirements String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  
  @@index([departmentId])
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  breakStart  DateTime?
  breakEnd    DateTime?
  workHours   Float?
  isLate      Boolean  @default(false)
  notes       String?
  location    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model Leave {
  id          String     @id @default(cuid())
  employeeId  String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String
  status      LeaveStatus @default(PENDING)
  rejectionReason String?
  
  approvedBy  String?
  approvedAt  DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model PerformanceReview {
  id          String   @id @default(cuid())
  employeeId  String
  reviewerId  String
  period      String
  rating      Float
  strengths   String?
  weaknesses  String?
  goals       String?
  comments    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([period])
}

model Document {
  id          String   @id @default(cuid())
  employeeId  String
  title       String
  type        String
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  
  uploadedBy  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([type])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  changes     String?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model DepartmentWorkflow {
  id          String         @id @default(cuid())
  departmentId String
  name        String
  description String?
  entityType  String         // LEAVE, EXPENSE, PROMOTION, etc.
  status      WorkflowStatus @default(DRAFT)
  version     Int            @default(1)
  
  // Workflow configuration
  config      Json           // Steps, conditions, rules
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  department  Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  
  @@index([departmentId])
  @@index([entityType])
  @@index([status])
}

model WorkflowStep {
  id          String           @id @default(cuid())
  workflowId  String
  name        String
  description String?
  type        WorkflowStepType
  order       Int
  
  // Step configuration
  config      Json             // Approvers, conditions, actions
  isRequired  Boolean          @default(true)
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  workflow    DepartmentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  @@index([workflowId])
  @@index([order])
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  workflowId  String
  entityId    String   // ID of the entity being processed
  entityType  String
  status      WorkflowStatus @default(DRAFT)
  currentStep Int      @default(0)
  
  // Execution data
  data        Json     // Form data, request details
  result      Json?    // Final result
  
  initiatedBy String
  completedAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  workflow    DepartmentWorkflow @relation(fields: [workflowId], references: [id])
  approvals   WorkflowApproval[]
  
  @@index([workflowId])
  @@index([entityId])
  @@index([status])
}

model WorkflowApproval {
  id          String   @id @default(cuid())
  executionId String
  stepId      String
  approverId  String
  status      String   // PENDING, APPROVED, REJECTED
  comments    String?
  
  approvedAt  DateTime?
  rejectedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId])
  @@index([approverId])
  @@index([status])
}

model DepartmentPolicy {
  id          String   @id @default(cuid())
  departmentId String
  name        String
  description String?
  type        String   // LEAVE_POLICY, WORK_HOURS, DRESS_CODE, etc.
  content     Json     // Policy details, rules
  
  isActive    Boolean  @default(true)
  effectiveFrom DateTime
  effectiveTo DateTime?
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  @@index([departmentId])
  @@index([type])
  @@index([isActive])
}

// Employee 360 Profile Models

model EmploymentHistory {
  id          String   @id @default(cuid())
  employeeId  String
  company     String
  position    String
  department  String?
  startDate   DateTime
  endDate     DateTime?
  description String?
  reasonForLeaving String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([startDate])
}

model Contract {
  id          String         @id @default(cuid())
  employeeId  String
  type        ContractType
  status      ContractStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime?
  salary      Float?
  benefits    Json?          // Benefits package details
  terms       Json?          // Contract terms and conditions
  documentUrl String?
  
  signedBy    String?
  signedAt    DateTime?
  approvedBy  String?
  approvedAt  DateTime?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model Certification {
  id          String   @id @default(cuid())
  employeeId  String
  name        String
  issuingBody String
  certificateNumber String?
  issueDate   DateTime
  expiryDate  DateTime?
  documentUrl String?
  status      String   @default("VALID") // VALID, EXPIRED, REVOKED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([expiryDate])
}

model Skill {
  id          String     @id @default(cuid())
  employeeId  String
  name        String
  category    String?   // Technical, Soft Skills, Language, etc.
  level       SkillLevel @default(BEGINNER)
  yearsOfExperience Float?
  verified    Boolean   @default(false)
  verifiedBy  String?
  verifiedAt  DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([category])
}

model TrainingRecord {
  id          String         @id @default(cuid())
  employeeId  String
  title       String
  description String?
  provider    String
  type        String?        // INTERNAL, EXTERNAL, ONLINE, WORKSHOP
  status      TrainingStatus @default(SCHEDULED)
  startDate   DateTime
  endDate     DateTime?
  location    String?
  cost        Float?
  certificateUrl String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model Asset {
  id          String      @id @default(cuid())
  employeeId  String
  name        String
  type        String      // LAPTOP, PHONE, VEHICLE, EQUIPMENT, etc.
  serialNumber String?
  model       String?
  status      AssetStatus @default(ASSIGNED)
  assignedDate DateTime
  returnDate  DateTime?
  condition   String?
  notes       String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
}

model DisciplinaryRecord {
  id          String             @id @default(cuid())
  employeeId  String
  type        DisciplinaryType
  status      DisciplinaryStatus @default(PENDING)
  date        DateTime
  description String
  severity    String             // LOW, MEDIUM, HIGH, CRITICAL
  action      String?
  actionTaken  String?
  resolvedBy  String?
  resolvedAt  DateTime?
  appealDeadline DateTime?
  appealReason String?
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
  @@index([date])
}

model PromotionHistory {
  id          String       @id @default(cuid())
  employeeId  String
  type        PromotionType
  fromDate    DateTime
  toDate      DateTime?
  oldPosition String?
  newPosition String
  oldSalary   Float?
  newSalary   Float?
  reason      String
  approvedBy  String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([fromDate])
}

model SalaryHistory {
  id          String   @id @default(cuid())
  employeeId  String
  amount      Float
  currency    String   @default("KES")
  effectiveDate DateTime
  reason      String
  type        String   @default("INCREMENT") // INCREMENT, DECREMENT, BONUS, ADJUSTMENT
  approvedBy  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([effectiveDate])
}

model Dependant {
  id          String   @id @default(cuid())
  employeeId  String
  firstName   String
  lastName    String
  relationship String
  dateOfBirth DateTime?
  gender      String?
  occupation  String?
  phone       String?
  isEmergency Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([isEmergency])
}
