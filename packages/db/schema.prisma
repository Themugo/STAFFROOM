  updatedAt   DateTime       @updatedAt
  
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([deviceId])
  @@index([status])
}

model AttendanceLocation {
