  approvedBy      String?
  approvedAt      DateTime?
  
  // Notes
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  assignments     RosterAssignment[]
  
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
  @@index([startDate])
}

model RosterAssignment {
  id              String        @id @default(cuid())
  rosterId        String
  employeeId      String
  
  rosterDate      DateTime
  shiftTemplateId String?
  
  // Position in roster (for drag-and-drop)
  position        Int?
  
  // Notes
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  roster          DutyRoster    @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  employee        Employee      @relation("EmployeeRosterAssignments", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([rosterId, employeeId, rosterDate])
  @@index([rosterId])
  @@index([employeeId])
  @@index([rosterDate])
}

model CompensationRule {
  id              String              @id @default(cuid())
  companyId       String
  
  name            String
  description     String?
  
  type            CompensationRuleType
  
  // Rule configuration
  hoursWorked     Float               // Hours worked threshold
  creditEarned    Float               // Credit earned
  multiplier      Float?              // Multiplier for weekends/holidays
  
  // Applicability
  appliesTo       Json?               // e.g., {"days": ["SATURDAY", "SUNDAY"], "shifts": ["NIGHT"]}
  
  enabled         Boolean             @default(true)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  credits         CompensationCredit[]
  
  @@index([companyId])
  @@index([type])
  @@index([enabled])
}

model CompensationCredit {
  id              String            @id @default(cuid())
  companyId       String
  employeeId      String
  ruleId          String
  
  type            CompensationType
  
  // Hours worked
  hoursWorked     Float
  
  // Credit earned
  creditEarned    Float             // In hours or days
  creditUsed      Float             @default(0) // Credit used (taken as leave)
  
  // Reference
  referenceDate   DateTime          // Date when hours were worked
  referenceType   String?           // e.g., "ATTENDANCE", "SHIFT"
  referenceId     String?
  
  // Expiry
  expiresAt       DateTime?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee          @relation("EmployeeCompensationCredits", fields: [employeeId], references: [id], onDelete: Cascade)
  rule            CompensationRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([ruleId])
  @@index([referenceDate])
  @@index([expiresAt])
}

// Phase 22: Time Bank & Days Owed Models
model TimeBank {
  id              String                  @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Balance tracking
  hoursEarned     Float                   @default(0)
  hoursUsed       Float                   @default(0)
  hoursRemaining  Float                   @default(0)
  
  // Settings
  expiresAfter    Int?                    // Days after which hours expire
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee                @relation("EmployeeTimeBank", fields: [employeeId], references: [id], onDelete: Cascade)
  transactions    TimeBankTransaction[]
  
  @@unique([companyId, employeeId])
  @@index([companyId])
  @@index([employeeId])
}

model TimeBankTransaction {
  id              String                  @id @default(cuid())
  timeBankId      String
  
  type            TimeBankTransactionType
  
  hours           Float
  description     String?
  
  // Reference
  referenceDate   DateTime
  referenceType   String?                 // e.g., "OVERTIME", "COMPENSATION_LEAVE", "ADJUSTMENT"
  referenceId     String?
  
  createdAt       DateTime                @default(now())
  
  timeBank        TimeBank                @relation(fields: [timeBankId], references: [id], onDelete: Cascade)
  
  @@index([timeBankId])
  @@index([referenceDate])
  @@index([type])
}

model EmployeeDebt {
  id              String        @id @default(cuid())
  companyId       String
  employeeId      String
  
  type            DebtType
  
  // Amount owed (in days or hours)
  daysOwed        Float         @default(0)
  hoursOwed       Float         @default(0)
  
  // Amount repaid
  daysRepaid      Float         @default(0)
  hoursRepaid     Float         @default(0)
  
  // Description
  description     String        @db.Text
  
  // Reference
  referenceDate   DateTime
  referenceType   String?       // e.g., "LATE_ARRIVAL", "UNAPPROVED_ABSENCE"
  referenceId     String?
  
  // Status
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee      @relation("EmployeeDebts", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([type])
  @@index([isResolved])
}

model EmployeeCredit {
  id              String        @id @default(cuid())
  companyId       String
  employeeId      String
  
  type            CreditType
  
  // Amount owed by company (in days or hours)
  daysOwed        Float         @default(0)
  hoursOwed       Float         @default(0)
  
  // Amount used
  daysUsed        Float         @default(0)
  hoursUsed       Float         @default(0)
  
  // Description
  description     String        @db.Text
  
  // Reference
  referenceDate   DateTime
  referenceType   String?       // e.g., "OVERTIME", "REST_DAY", "PUBLIC_HOLIDAY", "UNUSED_LEAVE"
  referenceId     String?
  
  // Expiry
  expiresAt       DateTime?
  
  // Status
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee      @relation("EmployeeCredits", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([type])
  @@index([expiresAt])
  @@index([isResolved])
}

// Phase 23: Workforce Balancing & Department Hub Models
model WorkforceBalance {
  id              String          @id @default(cuid())
  companyId       String
  departmentId    String
  
  // Shift/Date context
  shiftTemplateId String?
  date            DateTime
  
  // Staffing requirements
  requiredStaff   Int
  assignedStaff   Int
  gap             Int             // Can be positive (understaffed) or negative (overstaffed)
  
  // Status
  status          StaffingStatus
  
  // Details
  details         Json?           // Additional context like shift type, time range
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  @@unique([departmentId, date, shiftTemplateId])
  @@index([companyId])
  @@index([departmentId])
  @@index([date])
  @@index([status])
}

model DepartmentPost {
  id              String              @id @default(cuid())
  companyId       String
  departmentId    String
  
  type            DepartmentPostType
  title           String
  content         String              @db.Text
  
  // Author
  authorId        String
  
  // Poll options (if type is POLL)
  pollOptions     Json?               // e.g., {"options": ["Option 1", "Option 2"], "votes": [5, 3]}
  
  // File attachment (if type is FILE)
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  
  // Meeting details (if type is MEETING_NOTE)
  meetingDate     DateTime?
  meetingAttendees Json?
  
  // Visibility
  isPinned        Boolean             @default(false)
  
  // Engagement
  likes           Int                 @default(0)
  comments        Int                 @default(0)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  author          Employee            @relation("DepartmentPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments        DepartmentComment[]
  
  @@index([companyId])
  @@index([departmentId])
  @@index([authorId])
  @@index([type])
  @@index([isPinned])
  @@index([createdAt])
}

model DepartmentComment {
  id              String          @id @default(cuid())
  postId          String
  authorId        String
  
  content         String          @db.Text
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  post            DepartmentPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          Employee        @relation("DepartmentCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  
  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
}

// Phase 24: Shift Swap & Coverage Planning Models
model ShiftSwapRequest {
  id              String        @id @default(cuid())
  companyId       String
  departmentId    String
  
  // Requester
  requesterId     String
  
  // Target employee (to swap with)
  targetEmployeeId String
  
  // Shift details
  requesterShiftDate DateTime
  requesterShiftTemplateId String?
  
  targetShiftDate DateTime
  targetShiftTemplateId String?
  
  // Status
  status          SwapStatus    @default(PENDING)
  
  // Workflow
  supervisorId    String?
  supervisorReviewAt DateTime?
  supervisorNotes String?
  
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  
  // Roster update
  rosterUpdated   Boolean       @default(false)
  rosterUpdatedAt DateTime?
  
  // Notes
  reason          String?       @db.Text
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  requester       Employee      @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  targetEmployee  Employee      @relation("SwapTarget", fields: [targetEmployeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([requesterId])
  @@index([targetEmployeeId])
  @@index([status])
  @@index([requesterShiftDate])
}

model CoverageWarning {
  id              String        @id @default(cuid())
  companyId       String
  departmentId    String
  
  // Shift/Date context
  shiftTemplateId String?
  date            DateTime
  
  // Warning type
  warningType     String        // e.g., "CRITICAL_SKILL_MISSING", "UNDERSTAFFED", "OVERSTAFFED"
  
  // Details
  skillRequired   String?       // e.g., "Certified Electrician", "ICU Nurse"
  skillMissing    Boolean       @default(true)
  
  // Severity
  severity        String        // e.g., "HIGH", "MEDIUM", "LOW"
  
  // Description
  description     String        @db.Text
  
  // Resolution
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  resolutionNotes String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([date])
  @@index([warningType])
  @@index([isResolved])
}

model WorkforceCalendarEvent {
  id              String              @id @default(cuid())
  companyId       String
  departmentId    String
  
  type            CalendarEventType
  
  // Event details
  title           String
  description     String?            @db.Text
  
  // Date/Time
  startDate       DateTime
  endDate         DateTime
  
  // Employee (if applicable)
  employeeId      String?
  
  // Reference
  referenceType   String?             // e.g., "SHIFT", "LEAVE", "TRAINING", "MEETING"
  referenceId     String?
  
  // Location
  location        String?
  
  // Color (for calendar UI)
  color           String?
  
  // All day event
  isAllDay        Boolean             @default(false)
  
  // Recurrence
  isRecurring     Boolean             @default(false)
  recurrenceRule  Json?               // e.g., {"frequency": "WEEKLY", "days": ["MONDAY", "FRIDAY"]}
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employee        Employee?           @relation("CalendarEventEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([employeeId])
  @@index([type])
  @@index([startDate])
  @@index([endDate])
}

// Phase 25: Attendance Reconciliation & Workforce Planning Models
model AttendanceReconciliation {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Scheduled time (from roster)
  scheduledDate   DateTime
  scheduledTime   DateTime
  
  // Actual time (from attendance)
  actualCheckIn   DateTime?
  actualCheckOut  DateTime?
  
  // Variance calculation
  varianceMinutes Int                 @default(0) // Can be positive (late) or negative (early)
  
  // Status
  status          ReconciliationStatus
  
  // Calculated values
  latenessMinutes Float?             @default(0)
  overtimeHours   Float?             @default(0)
  compensationCredits Float?         @default(0)
  owedHours       Float?             @default(0)
  
  // Reference
  rosterAssignmentId String?
  attendanceId     String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("AttendanceReconciliation", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, scheduledDate])
  @@index([companyId])
  @@index([employeeId])
  @@index([scheduledDate])
  @@index([status])
}

model WorkforceForecast {
  id              String        @id @default(cuid())
  companyId       String
  
  // Scope
  departmentId    String?
  branchId        String?
  shiftTemplateId String?
  
  // Forecast period
  period          PlanningPeriod
  startDate       DateTime
  endDate         DateTime
  
  // Staffing requirements
  requiredStaff   Int
  currentStaff    Int
  gap             Int             // Can be positive (need more) or negative (excess)
  
  // Skill requirements
  skillRequired   String?        // e.g., "Certified Electrician", "ICU Nurse"
  skillCurrent     Int?          // Current count of staff with this skill
  skillGap        Int?          // Gap in skill requirements
  
  // Details
  details         Json?         // Additional context
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([branchId])
  @@index([period])
  @@index([startDate])
}

// Governance Layer Models

// Audit Engine - Immutable audit logs
model AuditLog {
  id              String      @id @default(cuid())
  companyId       String
  eventId         String      @unique
  entityType      String      // SHIFT, LEAVE, PAYROLL, ATTENDANCE, etc.
  entityId        String
  action          AuditAction
  beforeState     Json?
  afterState      Json?
  performedBy     String      // Employee ID
  approvedBy      String?     // Employee ID if approval required
  timestamp       DateTime    @default(now())
  device          String?
  ipAddress       String?
  userAgent       String?
  tenant          String      // Company identifier for multi-tenant
  
  createdAt       DateTime    @default(now())
  
  // Relations
  company         Company     @relation("AuditLogCompany", fields: [companyId], references: [id], onDelete: Cascade)
  performer       Employee    @relation("AuditLogPerformer", fields: [performedBy], references: [id], onDelete: Cascade)
  approver        Employee?   @relation("AuditLogApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([performedBy])
  @@index([timestamp])
  @@index([eventId])
}

// Liability Engine - Ownership tracking
model LiabilityRecord {
  id              String            @id @default(cuid())
  companyId       String
  eventType       LiabilityEventType
  entity          String            // SHIFT, LEAVE, PAYROLL, etc.
  entityId        String
  liableParty     String            // Employee ID who is liable
  liablePartyRole String            // SCHEDULER, REQUESTOR, ACCEPTOR, APPROVER, etc.
  context         Json?             // Additional context
  timestamp       DateTime          @default(now())
  
  createdAt       DateTime          @default(now())
  
  // Relations
  company         Company           @relation("LiabilityRecordCompany", fields: [companyId], references: [id], onDelete: Cascade)
  liableEmployee  Employee          @relation("LiabilityRecordLiable", fields: [liableParty], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([eventType])
  @@index([entity])
  @@index([entityId])
  @@index([liableParty])
  @@index([timestamp])
}

// Attendance Verification Engine
model AttendanceVerification {
  id              String            @id @default(cuid())
  companyId       String
  attendanceId    String
  employeeId      String
  verificationScore Int             @default(0) // 0-100
  status          VerificationStatus @default(PENDING)
  
  // Evidence points
  gpsMatch        Boolean           @default(false)
  gpsPoints       Int               @default(0)
  registeredDevice Boolean          @default(false)
  devicePoints    Int               @default(0)
  selfieVerification Boolean       @default(false)
  selfiePoints    Int               @default(0)
  supervisorConfirmation Boolean    @default(false)
  supervisorPoints Int              @default(0)
  shiftAssignmentMatch Boolean     @default(false)
  shiftPoints     Int               @default(0)
  
  // Verification details
  gpsLocation     Json?
  deviceId        String?
  selfieImage     String?
  supervisorId    String?
  
  // Flagging
  flagged         Boolean           @default(false)
  flagReason      String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  company         Company           @relation("AttendanceVerificationCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee          @relation("AttendanceVerificationEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  supervisor      Employee?         @relation("AttendanceVerificationSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([attendanceId])
  @@index([employeeId])
  @@index([status])
  @@index([verificationScore])
  @@index([flagged])
}

// Payroll Reconciliation Engine
model PayrollReconciliation {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  payrollPeriodId String
  status          ReconciliationStatus @default(PENDING)
  
  // Hours comparison
  scheduledHours  Float               @default(0)
  workedHours     Float               @default(0)
  overtimeHours   Float               @default(0)
  compensationDays Int                @default(0)
  leaveTaken      Float               @default(0)
  payableHours    Float               @default(0)
  
  // Discrepancies
  discrepancies   Json?
  resolved        Boolean             @default(false)
  resolutionNotes String?
  
  // Lock status
  locked          Boolean             @default(false)
  lockedBy        String?
  lockedAt        DateTime?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("PayrollReconciliationCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("PayrollReconciliationEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  lockedByUser    Employee?           @relation("PayrollReconciliationLockedBy", fields: [lockedBy], references: [id], onDelete: SetNull)
  
  @@unique([companyId, employeeId, payrollPeriodId])
  @@index([companyId])
  @@index([employeeId])
  @@index([payrollPeriodId])
  @@index([status])
  @@index([locked])
}

// Dispute Resolution Center
model WorkforceDispute {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  category        DisputeCategory
  status          DisputeStatus   @default(OPEN)
  title           String
  description     String
  
  // Related entities
  relatedEntity   String?         // SHIFT, LEAVE, PAYROLL, etc.
  relatedEntityId String?
  
  // Evidence bundle
  evidenceBundle  Json?           // Automatically gathered evidence
  
  // Resolution
  resolution      String?
  resolvedBy      String?
  resolvedAt      DateTime?
  
  // Priority
  priority        String          @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  company         Company         @relation("WorkforceDisputeCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation("WorkforceDisputeEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  resolver        Employee?       @relation("WorkforceDisputeResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([category])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

// Department Communication Audit
model AuditableCommunication {
  id              String              @id @default(cuid())
  companyId       String
  departmentId    String
  postId          String              // Reference to DepartmentPost
  type            CommunicationType
  title           String
  content         String
  
  // Read receipts
  readReceipts    Json?               // Array of read receipt objects
  
  // Audit
  sentBy          String
  sentAt          DateTime            @default(now())
  
  createdAt       DateTime            @default(now())
  
  // Relations
  company         Company             @relation("AuditableCommunicationCompany", fields: [companyId], references: [id], onDelete: Cascade)
  department      Department         @relation("AuditableCommunicationDepartment", fields: [departmentId], references: [id], onDelete: Cascade)
  sender          Employee            @relation("AuditableCommunicationSender", fields: [sentBy], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([postId])
  @@index([type])
  @@index([sentAt])
}

model CommunicationReadReceipt {
  id              String              @id @default(cuid())
  communicationId String
  employeeId      String
  status          ReadReceiptStatus   @default(SENT)
  
  sentAt          DateTime            @default(now())
  deliveredAt     DateTime?
  readAt          DateTime?
  acknowledgedAt  DateTime?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  communication    AuditableCommunication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("CommunicationReadReceiptEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([communicationId, employeeId])
  @@index([communicationId])
  @@index([employeeId])
  @@index([status])
}

// Payroll Evidence Pack
model PayrollEvidencePack {
  id              String      @id @default(cuid())
  companyId       String
  employeeId      String
  payrollId       String
  
  // Evidence components
  attendanceSummary Json?
  shiftHistory     Json?
  overtimeHistory  Json?
  leaveHistory     Json?
  compensationHistory Json?
  approvals        Json?
  
  // Generated
  generatedAt      DateTime    @default(now())
  generatedBy      String
  
  createdAt       DateTime    @default(now())
  
