  extensionApprover Employee?     @relation("ActingAppointmentExtensionApprover", fields: [extensionApprovedBy], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}
