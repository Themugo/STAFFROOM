  employee        Employee    @relation("PayrollEvidencePackEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  generator       Employee    @relation("PayrollEvidencePackGenerator", fields: [generatedBy], references: [id], onDelete: Cascade)
  
  @@unique([companyId, employeeId, payrollId])
  @@index([companyId])
  @@index([employeeId])
  @@index([payrollId])
  @@index([generatedAt])
}

// Governance Dashboard Metrics
model GovernanceMetric {
  id              String      @id @default(cuid())
  companyId       String
  metricType      String      // ATTENDANCE_EXCEPTIONS, PAYROLL_EXCEPTIONS, etc.
  metricValue     Float
  metricLabel     String
  period          String      // DAILY, WEEKLY, MONTHLY
  periodStart     DateTime
  periodEnd       DateTime
  
  // Breakdown
  breakdown       Json?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
