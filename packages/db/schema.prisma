// Recruitment Module Models

model Vacancy {
  id          String        @id @default(cuid())
  title       String
  description String
  departmentId String
  positionId  String
  location    String?
  employmentType String     // FULL_TIME, PART_TIME, CONTRACT, INTERNSHIP
  salaryMin   Float?
  salaryMax   Float?
  requirements String?
  responsibilities String?
  benefits    String?
  status      VacancyStatus @default(DRAFT)
  publishedAt DateTime?
  deadline    DateTime?
  positions   Int           @default(1)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  department  Department    @relation(fields: [departmentId], references: [id])
  position    Position      @relation(fields: [positionId], references: [id])
  applications Application[]
  
  @@index([departmentId])
  @@index([status])
  @@index([deadline])
}

model Candidate {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  location    String?
  resumeUrl   String?
  linkedInUrl String?
  portfolioUrl String?
  notes       String?
  
  source      String?  // REFERRAL, LINKEDIN, JOB_BOARD, WEBSITE, OTHER
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  applications Application[]
  
  @@index([email])
  @@index([source])
}

model Application {
  id          String            @id @default(cuid())
  vacancyId   String
  candidateId String
  status      ApplicationStatus @default(APPLIED)
  
  coverLetter String?
  expectedSalary Float?
  availableDate DateTime?
  
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  vacancy     Vacancy           @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviews  Interview[]
  
  @@unique([vacancyId, candidateId])
  @@index([vacancyId])
  @@index([candidateId])
  @@index([status])
}

model Interview {
  id          String          @id @default(cuid())
  applicationId String
  type        String          // PHONE, VIDEO, IN_PERSON, TECHNICAL
  status      InterviewStatus @default(SCHEDULED)
  
  scheduledDate DateTime
  duration    Int?            // In minutes
  location    String?
  notes       String?
  feedback    String?
  rating      Float?          // 1-5 scale
  
  interviewerId String?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  application Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  @@index([applicationId])
  @@index([status])
  @@index([scheduledDate])
}

model Onboarding {
  id          String          @id @default(cuid())
  employeeId  String
  status      OnboardingStatus @default(PENDING)
  
  startDate   DateTime
  endDate     DateTime?
  
  tasks       Json            // Onboarding checklist
  completedTasks Json?
  
  mentorId    String?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([status])
}

// Universal Workflow Engine Models

model WorkflowTemplate {
  id          String            @id @default(cuid())
  name        String
  description String?
  category    WorkflowCategory
  version     Int               @default(1)
  isActive    Boolean           @default(true)
  
  triggerType WorkflowTriggerType @default(MANUAL)
  triggerConfig Json?           // Trigger configuration
  
  createdBy   String
  updatedBy   String?
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  steps       WorkflowStep[]
  executions  WorkflowExecution[]
  workflowNodes WorkflowNode[] @relation("WorkflowNodes")
  
  @@index([category])
  @@index([isActive])
  @@index([version])
}

model WorkflowStep {
  id          String          @id @default(cuid())
  templateId  String
  name        String
  description String?
  type        StepType
  order       Int
  
  config      Json            // Step configuration (approval rules, conditions, etc.)
  
  isRequired  Boolean         @default(true)
  canSkip     Boolean         @default(false)
  
  timeoutMinutes Int?         // Timeout for this step
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  template    WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  executions  WorkflowStepExecution[]
  
  @@index([templateId])
  @@index([order])
  @@index([type])
}

model WorkflowExecution {
  id          String            @id @default(cuid())
  templateId  String
  category    WorkflowCategory
  
  status      ExecutionStatus   @default(STARTED)
  
  initiatedBy String
  entityId    String?           // Reference to the entity (leaveId, expenseId, etc.)
  entityType  String?           // Type of entity (LEAVE, EXPENSE, etc.)
  
  currentStep Int               @default(0)
  totalSteps  Int
  
  metadata    Json             // Additional execution data
  result      Json?            // Final result
  
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  template    WorkflowTemplate @relation(fields: [templateId], references: [id])
  stepExecutions WorkflowStepExecution[]
  approvals   WorkflowApproval[]
  
  @@index([templateId])
  @@index([category])
  @@index([status])
  @@index([entityId])
  @@index([initiatedBy])
}

model WorkflowStepExecution {
  id          String      @id @default(cuid())
  executionId String
  stepId      String
  
  status      StepStatus @default(PENDING)
  
  assignedTo  String?    // User or role assigned to this step
  assignedType String?   // USER or ROLE
  
  startedAt   DateTime?
  completedAt DateTime?
  
  metadata    Json        // Step-specific data
  result      Json?       // Step result
  
  comments    String?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step        WorkflowStep @relation(fields: [stepId], references: [id])
  
  @@index([executionId])
  @@index([stepId])
  @@index([status])
  @@index([assignedTo])
}

model WorkflowApproval {
  id          String      @id @default(cuid())
  executionId String
  stepExecutionId String?
  
  approverId  String
  status      String      // APPROVED, REJECTED, PENDING
  
  comments    String?
  
  approvedAt  DateTime?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId])
  @@index([approverId])
  @@index([status])
}

// Enterprise Security Models

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model MultiFactorAuth {
  id          String    @id @default(cuid())
  userId      String
  type        MFAType
  secret      String?   // For TOTP
  phoneNumber String?   // For SMS
  email       String?   // For Email
  status      MFAStatus @default(DISABLED)
  
  backupCodes Json?     // Backup codes for recovery
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
}

model LoginHistory {
  id          String    @id @default(cuid())
  userId      String
  
  ipAddress   String?
  userAgent   String?
  deviceType  String?
  browser     String?
  os          String?
  
  loginTime   DateTime  @default(now())
  logoutTime  DateTime?
  status      String    // SUCCESS, FAILED, BLOCKED
  failureReason String?
  
  location    Json?     // { city, country, latitude, longitude }
  
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([loginTime])
  @@index([status])
}

model DeviceSession {
  id          String        @id @default(cuid())
  userId      String
  
  deviceName  String
  deviceType  String        // MOBILE, TABLET, DESKTOP
  deviceFingerprint String  // Unique device identifier
  
  ipAddress   String?
  userAgent   String?
  
  lastActive  DateTime      @default(now())
  expiresAt   DateTime
  status      SessionStatus @default(ACTIVE)
  
  isTrusted   Boolean       @default(false)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([deviceFingerprint])
  @@index([status])
  @@index([expiresAt])
}

model AuditLog {
  id          String        @id @default(cuid())
  userId      String?
  
  action      AuditAction
  severity    AuditSeverity @default(INFO)
  
  entityType  String        // User, Employee, Department, etc.
  entityId    String?
  
  description String
  metadata    Json?         // Additional context
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime      @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Permission {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  
  resource    String        // employees, departments, payroll, etc.
  action      String        // create, read, update, delete
  
  scope       PermissionScope @default(GLOBAL)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  rolePermissions RolePermission[]
  
  @@index([resource])
  @@index([action])
  @@index([scope])
}

model RolePermission {
  id          String    @id @default(cuid())
  roleId      String
  permissionId String
  
  createdAt   DateTime  @default(now())
  
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model Tenant {
  id          String    @id @default(cuid())
  name        String
  domain      String    @unique
  subdomain   String?   @unique
  
  isActive    Boolean   @default(true)
  
  encryptionKey String?  // For data encryption at rest
  
  settings    Json?     // Tenant-specific settings
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  companies   Company[]
  users       User[]
  
  @@index([domain])
  @@index([subdomain])
  @@index([isActive])
}

