# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/staffroom
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_this_in_production
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
PORT=5000

# API Configuration
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Session
SESSION_SECRET=your_session_secret_change_this_in_production
SESSION_MAX_AGE=86400000

# Redis (for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Service (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_password
SMTP_FROM=noreply@staffroom.ke

# File Storage (for document uploads)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=staffroom-documents
AWS_S3_REGION=us-east-1

# Payment Gateway (for payroll features)
STRIPE_SECRET=change_me
STRIPE_WEBHOOK_SECRET=change_me

# Monitoring & Logging
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info

# Analytics
GOOGLE_ANALYTICS_ID=

# Mobile App
MOBILE_API_KEY=

# External Integrations
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Backup
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true

# Feature Flags
ENABLE_MOBILE_APP=true
ENABLE_PAYROLL=true
ENABLE_BIOMETRIC=false
