# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/staffroom

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development

# Optional: Payment Gateway (for future payroll features)
STRIPE_SECRET=change_me

# Optional: Email Service (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_password

# Optional: File Storage (for document uploads)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=staffroom-documents
