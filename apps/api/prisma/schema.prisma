  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  @@index([path])
  @@index([method])
  @@index([category])
  @@index([status])
}

model DeveloperAccount {
  id              String        @id @default(cuid())
  
  email           String        @unique
  name            String
  
  organization    String?
  
  apiKey          String        @unique
  apiSecret       String
  
  scopes          Json?         // Array of scopes
  rateLimit       Int           @default(1000)
  
  enabled         Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([email])
  @@index([apiKey])
  @@index([enabled])
}

// Phase 20: Advanced Shift Management Models
model ShiftTemplate {
  id              String        @id @default(cuid())
  companyId       String
  departmentId    String?
  
  name            String
  description     String?
  
  type            ShiftType
  status          ShiftStatus   @default(ACTIVE)
  
  // Shift timing
  startTime       String        // e.g., "06:00"
  endTime         String        // e.g., "14:00"
  duration        Int           // Duration in minutes
  
  // Break periods
  breakPeriods    Json?         // Array of break periods [{start, end, duration}]
  
  // Grace periods
  gracePeriodStart Int?         // Grace period before shift start (minutes)
  gracePeriodEnd   Int?         // Grace period after shift end (minutes)
  
  // Rotation configuration
  rotationPattern  RotationPattern?
  rotationDays     Json?         // Array of days for rotation
  rotationCycle    Int?          // Rotation cycle in days
  
  // Color coding for calendar view
  color           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  assignments     ShiftAssignment[]
  rotations       ShiftRotation[]
  schedules       ShiftSchedule[]
  
  @@index([companyId])
  @@index([departmentId])
  @@index([type])
  @@index([status])
}

model ShiftAssignment {
  id              String        @id @default(cuid())
  templateId      String
  employeeId      String
  
  startDate       DateTime
  endDate         DateTime?
  
  isActive        Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  template        ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  employee        Employee      @relation("EmployeeShiftAssignments", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([templateId, employeeId, startDate])
  @@index([templateId])
  @@index([employeeId])
  @@index([startDate])
}

model ShiftRotation {
  id              String        @id @default(cuid())
  templateId      String
  
  name            String
  description     String?
  
  pattern         RotationPattern
  cycleDays       Int           // Number of days in rotation cycle
  
  // Rotation schedule
  rotationSchedule Json         // e.g., [{"day": 1, "shift": "DAY"}, {"day": 2, "shift": "NIGHT"}]
  
  // Auto-assign rules
  autoAssign      Boolean       @default(false)
  autoAssignRules Json?         // Rules for automatic assignment
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  template        ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  @@index([templateId])
  @@index([pattern])
}

model ShiftSchedule {
  id              String        @id @default(cuid())
  templateId      String
  employeeId      String?
  
  scheduledDate   DateTime
  scheduledStart  DateTime
  scheduledEnd    DateTime
  
  // Actual clock in/out
  actualStart     DateTime?
  actualEnd       DateTime?
  
  status          ShiftStatus   @default(ACTIVE)
  
  // Notes
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  template        ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  @@index([templateId])
  @@index([employeeId])
  @@index([scheduledDate])
  @@index([status])
}

// Phase 21: Duty Roster & Compensation Calendar Models
model DutyRoster {
  id              String        @id @default(cuid())
  companyId       String
  departmentId    String
  
  name            String
  description     String?
  
  startDate       DateTime
  endDate         DateTime
  
  status          RosterStatus  @default(DRAFT)
  
  // Roster permissions
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  
  // Notes
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  assignments     RosterAssignment[]
  
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
  @@index([startDate])
}

model RosterAssignment {
  id              String        @id @default(cuid())
  rosterId        String
  employeeId      String
  
  rosterDate      DateTime
  shiftTemplateId String?
  
  // Position in roster (for drag-and-drop)
  position        Int?
  
  // Notes
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  roster          DutyRoster    @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  employee        Employee      @relation("EmployeeRosterAssignments", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([rosterId, employeeId, rosterDate])
  @@index([rosterId])
  @@index([employeeId])
  @@index([rosterDate])
}

model CompensationRule {
  id              String              @id @default(cuid())
  companyId       String
  
  name            String
  description     String?
  
  type            CompensationRuleType
  
  // Rule configuration
  hoursWorked     Float               // Hours worked threshold
  creditEarned    Float               // Credit earned
  multiplier      Float?              // Multiplier for weekends/holidays
  
  // Applicability
  appliesTo       Json?               // e.g., {"days": ["SATURDAY", "SUNDAY"], "shifts": ["NIGHT"]}
  
  enabled         Boolean             @default(true)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  credits         CompensationCredit[]
  
  @@index([companyId])
  @@index([type])
  @@index([enabled])
}

model CompensationCredit {
  id              String            @id @default(cuid())
  companyId       String
  employeeId      String
  ruleId          String
  
  type            CompensationType
  
  // Hours worked
  hoursWorked     Float
  
  // Credit earned
  creditEarned    Float             // In hours or days
  creditUsed      Float             @default(0) // Credit used (taken as leave)
  
  // Reference
  referenceDate   DateTime          // Date when hours were worked
  referenceType   String?           // e.g., "ATTENDANCE", "SHIFT"
  referenceId     String?
  
  // Expiry
  expiresAt       DateTime?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee          @relation("EmployeeCompensationCredits", fields: [employeeId], references: [id], onDelete: Cascade)
  rule            CompensationRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([ruleId])
  @@index([referenceDate])
  @@index([expiresAt])
}

// Phase 22: Time Bank & Days Owed Models
model TimeBank {
  id              String                  @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Balance tracking
  hoursEarned     Float                   @default(0)
  hoursUsed       Float                   @default(0)
  hoursRemaining  Float                   @default(0)
  
  // Settings
  expiresAfter    Int?                    // Days after which hours expire
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee                @relation("EmployeeTimeBank", fields: [employeeId], references: [id], onDelete: Cascade)
  transactions    TimeBankTransaction[]
  
  @@unique([companyId, employeeId])
  @@index([companyId])
  @@index([employeeId])
}

model TimeBankTransaction {
  id              String                  @id @default(cuid())
  timeBankId      String
  
  type            TimeBankTransactionType
  
  hours           Float
  description     String?
  
  // Reference
  referenceDate   DateTime
  referenceType   String?                 // e.g., "OVERTIME", "COMPENSATION_LEAVE", "ADJUSTMENT"
  referenceId     String?
  
  createdAt       DateTime                @default(now())
  
  timeBank        TimeBank                @relation(fields: [timeBankId], references: [id], onDelete: Cascade)
  
  @@index([timeBankId])
  @@index([referenceDate])
  @@index([type])
}

model EmployeeDebt {
  id              String        @id @default(cuid())
  companyId       String
  employeeId      String
  
  type            DebtType
  
  // Amount owed (in days or hours)
  daysOwed        Float         @default(0)
  hoursOwed       Float         @default(0)
  
  // Amount repaid
  daysRepaid      Float         @default(0)
  hoursRepaid     Float         @default(0)
  
  // Description
  description     String        @db.Text
  
  // Reference
  referenceDate   DateTime
  referenceType   String?       // e.g., "LATE_ARRIVAL", "UNAPPROVED_ABSENCE"
  referenceId     String?
  
  // Status
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee      @relation("EmployeeDebts", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([type])
  @@index([isResolved])
}

model EmployeeCredit {
  id              String        @id @default(cuid())
  companyId       String
  employeeId      String
  
  type            CreditType
  
  // Amount owed by company (in days or hours)
  daysOwed        Float         @default(0)
  hoursOwed       Float         @default(0)
  
  // Amount used
  daysUsed        Float         @default(0)
  hoursUsed       Float         @default(0)
  
  // Description
  description     String        @db.Text
  
  // Reference
  referenceDate   DateTime
  referenceType   String?       // e.g., "OVERTIME", "REST_DAY", "PUBLIC_HOLIDAY", "UNUSED_LEAVE"
  referenceId     String?
  
  // Expiry
  expiresAt       DateTime?
  
  // Status
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee      @relation("EmployeeCredits", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([type])
  @@index([expiresAt])
  @@index([isResolved])
}

// Phase 23: Workforce Balancing & Department Hub Models
model WorkforceBalance {
  id              String          @id @default(cuid())
  companyId       String
  departmentId    String
  
  // Shift/Date context
  shiftTemplateId String?
  date            DateTime
  
  // Staffing requirements
  requiredStaff   Int
  assignedStaff   Int
  gap             Int             // Can be positive (understaffed) or negative (overstaffed)
  
  // Status
  status          StaffingStatus
  
  // Details
  details         Json?           // Additional context like shift type, time range
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  @@unique([departmentId, date, shiftTemplateId])
  @@index([companyId])
  @@index([departmentId])
  @@index([date])
  @@index([status])
}

model DepartmentPost {
  id              String              @id @default(cuid())
  companyId       String
  departmentId    String
  
  type            DepartmentPostType
  title           String
  content         String              @db.Text
  
  // Author
  authorId        String
  
  // Poll options (if type is POLL)
  pollOptions     Json?               // e.g., {"options": ["Option 1", "Option 2"], "votes": [5, 3]}
  
  // File attachment (if type is FILE)
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  
  // Meeting details (if type is MEETING_NOTE)
  meetingDate     DateTime?
  meetingAttendees Json?
  
  // Visibility
  isPinned        Boolean             @default(false)
  
  // Engagement
  likes           Int                 @default(0)
  commentCount    Int                 @default(0)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  author          Employee            @relation("DepartmentPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments        DepartmentComment[]
  
  @@index([companyId])
  @@index([departmentId])
  @@index([authorId])
  @@index([type])
  @@index([isPinned])
  @@index([createdAt])
}

model DepartmentComment {
  id              String          @id @default(cuid())
  postId          String
  authorId        String
  
  content         String          @db.Text
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  post            DepartmentPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          Employee        @relation("DepartmentCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  
  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
}

// Phase 24: Shift Swap & Coverage Planning Models
model ShiftSwapRequest {
  id              String        @id @default(cuid())
  companyId       String
  departmentId    String
  
  // Requester
  requesterId     String
  
  // Target employee (to swap with)
  targetEmployeeId String
  
  // Shift details
  requesterShiftDate DateTime
  requesterShiftTemplateId String?
  
  targetShiftDate DateTime
  targetShiftTemplateId String?
  
  // Status
  status          SwapStatus    @default(PENDING)
  
  // Workflow
  supervisorId    String?
  supervisorReviewAt DateTime?
  supervisorNotes String?
  
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  
  // Roster update
  rosterUpdated   Boolean       @default(false)
  rosterUpdatedAt DateTime?
  
  // Notes
  reason          String?       @db.Text
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  requester       Employee      @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  targetEmployee  Employee      @relation("SwapTarget", fields: [targetEmployeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([requesterId])
  @@index([targetEmployeeId])
  @@index([status])
  @@index([requesterShiftDate])
}

model CoverageWarning {
  id              String        @id @default(cuid())
  companyId       String
  departmentId    String
  
  // Shift/Date context
  shiftTemplateId String?
  date            DateTime
  
  // Warning type
  warningType     String        // e.g., "CRITICAL_SKILL_MISSING", "UNDERSTAFFED", "OVERSTAFFED"
  
  // Details
  skillRequired   String?       // e.g., "Certified Electrician", "ICU Nurse"
  skillMissing    Boolean       @default(true)
  
  // Severity
  severity        String        // e.g., "HIGH", "MEDIUM", "LOW"
  
  // Description
  description     String        @db.Text
  
  // Resolution
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  resolutionNotes String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([date])
  @@index([warningType])
  @@index([isResolved])
}

model WorkforceCalendarEvent {
  id              String              @id @default(cuid())
  companyId       String
  departmentId    String
  
  type            CalendarEventType
  
  // Event details
  title           String
  description     String?            @db.Text
  
  // Date/Time
  startDate       DateTime
  endDate         DateTime
  
  // Employee (if applicable)
  employeeId      String?
  
  // Reference
  referenceType   String?             // e.g., "SHIFT", "LEAVE", "TRAINING", "MEETING"
  referenceId     String?
  
  // Location
  location        String?
  
  // Color (for calendar UI)
  color           String?
  
  // All day event
  isAllDay        Boolean             @default(false)
  
  // Recurrence
  isRecurring     Boolean             @default(false)
  recurrenceRule  Json?               // e.g., {"frequency": "WEEKLY", "days": ["MONDAY", "FRIDAY"]}
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employee        Employee?           @relation("CalendarEventEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([employeeId])
  @@index([type])
  @@index([startDate])
  @@index([endDate])
}

// Phase 25: Attendance Reconciliation & Workforce Planning Models
model AttendanceReconciliation {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Scheduled time (from roster)
  scheduledDate   DateTime
  scheduledTime   DateTime
  
  // Actual time (from attendance)
  actualCheckIn   DateTime?
  actualCheckOut  DateTime?
  
  // Variance calculation
  varianceMinutes Int                 @default(0) // Can be positive (late) or negative (early)
  
  // Status
  status          ReconciliationStatus
  
  // Calculated values
  latenessMinutes Float?             @default(0)
  overtimeHours   Float?             @default(0)
  compensationCredits Float?         @default(0)
  owedHours       Float?             @default(0)
  
  // Reference
  rosterAssignmentId String?
  attendanceId     String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("AttendanceReconciliation", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, scheduledDate])
  @@index([companyId])
  @@index([employeeId])
  @@index([scheduledDate])
  @@index([status])
}

model WorkforceForecast {
  id              String        @id @default(cuid())
  companyId       String
  
  // Scope
  departmentId    String?
  branchId        String?
  shiftTemplateId String?
  
  // Forecast period
  period          PlanningPeriod
  startDate       DateTime
  endDate         DateTime
  
  // Staffing requirements
  requiredStaff   Int
  currentStaff    Int
  gap             Int             // Can be positive (need more) or negative (excess)
  
  // Skill requirements
  skillRequired   String?        // e.g., "Certified Electrician", "ICU Nurse"
  skillCurrent     Int?          // Current count of staff with this skill
  skillGap        Int?          // Gap in skill requirements
  
  // Details
  details         Json?         // Additional context
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([branchId])
  @@index([period])
  @@index([startDate])
}

// Governance Layer Models

// Audit Engine - Immutable audit logs
model AuditLog {
  id              String      @id @default(cuid())
  companyId       String
  eventId         String      @unique
  entityType      String      // SHIFT, LEAVE, PAYROLL, ATTENDANCE, etc.
  entityId        String
  action          AuditAction
  beforeState     Json?
  afterState      Json?
  performedBy     String      // Employee ID
  approvedBy      String?     // Employee ID if approval required
  timestamp       DateTime    @default(now())
  device          String?
  ipAddress       String?
  userAgent       String?
  tenant          String      // Company identifier for multi-tenant
  
  createdAt       DateTime    @default(now())
  
  // Relations
  company         Company     @relation("AuditLogCompany", fields: [companyId], references: [id], onDelete: Cascade)
  performer       Employee    @relation("AuditLogPerformer", fields: [performedBy], references: [id], onDelete: Cascade)
  approver        Employee?   @relation("AuditLogApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([performedBy])
  @@index([timestamp])
  @@index([eventId])
}

// Liability Engine - Ownership tracking
model LiabilityRecord {
  id              String            @id @default(cuid())
  companyId       String
  eventType       LiabilityEventType
  entity          String            // SHIFT, LEAVE, PAYROLL, etc.
  entityId        String
  liableParty     String            // Employee ID who is liable
  liablePartyRole String            // SCHEDULER, REQUESTOR, ACCEPTOR, APPROVER, etc.
  context         Json?             // Additional context
  timestamp       DateTime          @default(now())
  
  createdAt       DateTime          @default(now())
  
  // Relations
  company         Company           @relation("LiabilityRecordCompany", fields: [companyId], references: [id], onDelete: Cascade)
  liableEmployee  Employee          @relation("LiabilityRecordLiable", fields: [liableParty], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([eventType])
  @@index([entity])
  @@index([entityId])
  @@index([liableParty])
  @@index([timestamp])
}

// Attendance Verification Engine
model AttendanceVerification {
  id              String            @id @default(cuid())
  companyId       String
  attendanceId    String
  employeeId      String
  verificationScore Int             @default(0) // 0-100
  status          VerificationStatus @default(PENDING)
  
  // Evidence points
  gpsMatch        Boolean           @default(false)
  gpsPoints       Int               @default(0)
  registeredDevice Boolean          @default(false)
  devicePoints    Int               @default(0)
  selfieVerification Boolean       @default(false)
  selfiePoints    Int               @default(0)
  supervisorConfirmation Boolean    @default(false)
  supervisorPoints Int              @default(0)
  shiftAssignmentMatch Boolean     @default(false)
  shiftPoints     Int               @default(0)
  
  // Verification details
  gpsLocation     Json?
  deviceId        String?
  selfieImage     String?
  supervisorId    String?
  
  // Flagging
  flagged         Boolean           @default(false)
  flagReason      String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  company         Company           @relation("AttendanceVerificationCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee          @relation("AttendanceVerificationEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  supervisor      Employee?         @relation("AttendanceVerificationSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([attendanceId])
  @@index([employeeId])
  @@index([status])
  @@index([verificationScore])
  @@index([flagged])
}

// Payroll Reconciliation Engine
model PayrollReconciliation {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  payrollPeriodId String
  status          ReconciliationStatus @default(PENDING)
  
  // Hours comparison
