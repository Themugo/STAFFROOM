  @@index([companyId])
  @@index([meetingId])
  @@index([employeeId])
}

model CommitteeDecision {
  id              String              @id @default(cuid())
  companyId       String
  committeeId     String
  meetingId       String?
  
  // Decision Details
  title           String
  description     String?
  
  // Decision
  decisionType    String
  decision        String
  voteCount       Json?               // { for: number, against: number, abstain: number }
  
  // Date
  decisionDate    DateTime
  
  // Implementation
  implementationStatus String?
  implementationDate DateTime?
  
  // Documents
  decisionFile    String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("CommitteeDecisionCompany", fields: [companyId], references: [id], onDelete: Cascade)
  committee       Committee           @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  meeting         CommitteeMeeting?   @relation("MeetingCommitteeDecision", fields: [meetingId], references: [id])
  
  @@index([companyId])
  @@index([committeeId])
  @@index([meetingId])
  @@index([decisionDate])
}

// Phase 43: Project-based Reporting
model Project {
  id              String              @id @default(cuid())
  companyId       String
  departmentId    String?
  
  // Project Details
  name            String
  description     String?
  
  // Status
  status          ProjectStatus        @default(PLANNING)
  priority        ProjectPriority     @default(MEDIUM)
  
  // Timeline
  startDate       DateTime
  endDate         DateTime?
  actualEndDate   DateTime?
  
  // Budget
  budget          Float?
  actualCost      Float?
  currency        String              @default("USD")
  
  // Leadership
  managerId       String?
  
  // Progress
  progress        Float               @default(0)
  
  // Goals
  goals           Json?
  
  // Risks
  risks           Json?
  
  // Documents
  projectCharter  String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("ProjectCompany", fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?         @relation("ProjectDepartment", fields: [departmentId], references: [id])
  manager         Employee?           @relation("ProjectManager", fields: [managerId], references: [id])
  members         ProjectMember[]
  tasks           ProjectTask[]
  milestones      ProjectMilestone[]
  
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
  @@index([priority])
  @@index([startDate])
}

model ProjectMember {
  id              String              @id @default(cuid())
  companyId       String
  projectId       String
  employeeId      String
  
  // Member Details
  role            String
  joinDate        DateTime
  leaveDate       DateTime?
  
  // Responsibilities
  responsibilities Json?
  
  // Status
  active          Boolean             @default(true)
  
  // Allocation
  allocationPercentage Float?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("ProjectMemberCompany", fields: [companyId], references: [id], onDelete: Cascade)
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("EmployeeProjectMember", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, employeeId])
  @@index([companyId])
  @@index([projectId])
  @@index([employeeId])
  @@index([active])
}

model ProjectTask {
  id              String              @id @default(cuid())
  companyId       String
  projectId       String
  
  // Task Details
  title           String
  description     String?
  
  // Status
  status          ProjectStatus        @default(PLANNING)
  priority        ProjectPriority     @default(MEDIUM)
  
  // Assignment
  assignedTo      String?
  
  // Timeline
  startDate       DateTime
  dueDate         DateTime
  completedDate   DateTime?
  
  // Progress
  progress        Float               @default(0)
  
  // Dependencies
  dependsOn       Json?               // Array of task IDs
  
  // Documents
  attachments     Json?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("ProjectTaskCompany", fields: [companyId], references: [id], onDelete: Cascade)
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee        Employee?           @relation("ProjectTaskAssignee", fields: [assignedTo], references: [id])
  
  @@index([companyId])
  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
}

model ProjectMilestone {
  id              String              @id @default(cuid())
  companyId       String
  projectId       String
  
  // Milestone Details
  title           String
  description     String?
  
  // Date
  targetDate      DateTime
  achievedDate    DateTime?
  
  // Status
  achieved        Boolean             @default(false)
  
  // Deliverables
  deliverables    Json?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("ProjectMilestoneCompany", fields: [companyId], references: [id], onDelete: Cascade)
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([projectId])
  @@index([targetDate])
  @@index([achieved])
}

// Phase 44: Exam & Assessment Tracking
model Assessment {
  id              String              @id @default(cuid())
  companyId       String
  courseId        String?
  
  // Assessment Details
  title           String
  description     String?
  assessmentType  AssessmentType
  
  // Schedule
  scheduledDate   DateTime
  duration        Int?                // In minutes
  
  // Status
  status          AssessmentStatus    @default(SCHEDULED)
  
  // Scoring
  maxScore        Float
  passingScore    Float
  
  // Instructions
  instructions    String?
  
  // Settings
  allowRetake     Boolean             @default(false)
  maxAttempts     Int?
  
  // Documents
  assessmentFile  String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("AssessmentCompany", fields: [companyId], references: [id], onDelete: Cascade)
  course          Course?             @relation("CourseAssessment", fields: [courseId], references: [id])
  results         AssessmentResult[]
  
  @@index([companyId])
  @@index([courseId])
  @@index([scheduledDate])
  @@index([status])
}

model AssessmentResult {
  id              String              @id @default(cuid())
  companyId       String
  assessmentId    String
  employeeId      String
  
  // Result Details
  score           Float
  maxScore        Float
  percentage      Float
  
  // Status
  passed          Boolean
  
  // Attempt
  attemptNumber   Int                 @default(1)
  
  // Date
  takenDate       DateTime
  
  // Duration
  durationMinutes Int?
  
  // Feedback
  feedback        String?
  
  // Documents
  answerFile      String?
  
  createdAt       DateTime            @default(now())
  
  // Relations
  company         Company             @relation("AssessmentResultCompany", fields: [companyId], references: [id], onDelete: Cascade)
  assessment      Assessment          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("EmployeeAssessmentResult", fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([assessmentId])
  @@index([employeeId])
  @@index([takenDate])
}

// Phase 45: Fraud Detection Enhancements
model FraudAlert {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String?
  
  // Alert Details
  alertType       String
  description     String
  
  // Risk Assessment
  riskLevel       FraudRiskLevel
  confidenceScore Float?
  
  // Detection
  detectedDate    DateTime            @default(now())
  detectionMethod String?
  
  // Context
  context         Json?
  
  // Investigation
  caseId          String?
  investigatedBy  String?
  investigatedAt  DateTime?
  
  // Resolution
  resolved        Boolean             @default(false)
  resolvedAt      DateTime?
  resolutionNotes String?
  
  // Evidence
  evidenceFiles   Json?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("FraudAlertCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee?           @relation("EmployeeFraudAlert", fields: [employeeId], references: [id], onDelete: Cascade)
  case            FraudCase?          @relation("AlertFraudCase", fields: [caseId], references: [id])
  investigator    Employee?           @relation("FraudAlertInvestigator", fields: [investigatedBy], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([riskLevel])
  @@index([detectedDate])
  @@index([resolved])
}

model FraudCase {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String?
  
  // Case Details
  caseNumber      String              @unique
  title           String
  description     String
  
  // Status
  status          FraudCaseStatus     @default(REPORTED)
  
  // Risk Assessment
  riskLevel       FraudRiskLevel
  estimatedImpact Float?
  
  // Timeline
  reportedDate    DateTime            @default(now())
  investigationStartDate DateTime?
  resolvedDate    DateTime?
  
  // Investigation
  investigatorId  String?
  investigationNotes String?
  
  // Findings
  findings        String?
  substantiated    Boolean?
  
  // Resolution
  resolution      String?
  disciplinaryAction String?
  
  // Documents
  evidenceFiles   Json?
  reportFile      String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("FraudCaseCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee?           @relation("EmployeeFraudCases", fields: [employeeId], references: [id], onDelete: Cascade)
  alerts          FraudAlert[]        @relation("AlertFraudCase")
  investigator    Employee?           @relation("EmployeeFraudCasesAsInvestigator", fields: [investigatorId], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([reportedDate])
}

// Phase 46: Attrition Risk Prediction
model AttritionRisk {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Risk Assessment
  riskLevel       AttritionRiskLevel
  riskScore       Float
  
  // Risk Factors
  riskFactors     Json?               // Array of risk factors with scores
  
  // Primary Risk Factor
  primaryFactor   AttritionRiskFactor?
  
  // Prediction
  predictionDate  DateTime            @default(now())
  predictionHorizon Int?             // Days until potential departure
  
  // Historical Data
  tenure          Int?                // In days
  performanceRating Float?
  
  // Mitigation
  mitigationPlan  String?
  mitigationActions Json?
  
  // Follow-up
  reviewedBy      String?
  reviewDate      DateTime?
  reviewNotes     String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("AttritionRiskCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("EmployeeAttritionRisks", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer        Employee?           @relation("EmployeeAttritionRisksAsReviewer", fields: [reviewedBy], references: [id])
  interventions   AttritionIntervention[] @relation("EmployeeAttritionRisks")
  
  @@index([companyId])
  @@index([employeeId])
  @@index([riskLevel])
  @@index([predictionDate])
}

model AttritionIntervention {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  riskId          String?
  
  // Intervention Details
  interventionType String
  description     String
  
  // Timeline
  plannedDate     DateTime
  completedDate   DateTime?
  
  // Status
  status          ProjectStatus        @default(PLANNING)
  
  // Outcome
  outcome         String?
  effectiveness   Float?
  
  // Assignment
  assignedTo      String?
  
  // Notes
  notes           String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("AttritionInterventionCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("EmployeeAttritionInterventions", fields: [employeeId], references: [id], onDelete: Cascade)
  risk            AttritionRisk?       @relation("EmployeeAttritionRisks", fields: [riskId], references: [id])
  assignedToUser  Employee?           @relation("EmployeeAttritionInterventionsAsAssignedTo", fields: [assignedTo], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([riskId])
  @@index([plannedDate])
  @@index([status])
}

// Phase 47: Burnout Detection
model BurnoutRisk {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Risk Assessment
  riskLevel       BurnoutRiskLevel
  riskScore       Float
  
  // Indicators
  indicators      Json?               // Array of indicators with scores
  
  // Primary Indicator
  primaryIndicator BurnoutIndicator?
  
  // Assessment
  assessmentDate  DateTime            @default(now())
  
  // Metrics
  avgWorkHours    Float?
  overtimeHours   Float?
  absenteeismRate Float?
  performanceTrend String?
  
  // Self-reported
  stressLevel     Int?                // 1-10 scale
  satisfactionLevel Int?              // 1-10 scale
  
  // Recommendations
  recommendations Json?
  
  // Follow-up
  reviewedBy      String?
  reviewDate      DateTime?
  reviewNotes     String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("BurnoutRiskCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("EmployeeBurnoutRisks", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer        Employee?           @relation("EmployeeBurnoutRisksAsReviewer", fields: [reviewedBy], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([riskLevel])
  @@index([assessmentDate])
}

model WellnessProgram {
  id              String              @id @default(cuid())
  companyId       String
  
  // Program Details
  name            String
  description     String?
  
  // Type
  programType     String
  
  // Status
  active          Boolean             @default(true)
  
  // Schedule
  startDate       DateTime
  endDate         DateTime?
  
  // Capacity
  capacity        Int?
  currentEnrollment Int              @default(0)
  
  // Resources
  resources       Json?
  
  // Documents
  programDocument String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("WellnessProgramCompany", fields: [companyId], references: [id], onDelete: Cascade)
  enrollments     WellnessEnrollment[]
  
  @@index([companyId])
  @@index([active])
  @@index([startDate])
}

model WellnessEnrollment {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  programId       String
  
  // Enrollment Details
  enrollmentDate  DateTime
  completionDate  DateTime?
  
  // Status
  active          Boolean             @default(true)
  
  // Progress
  progress        Float               @default(0)
  
  // Feedback
  satisfaction    Int?                // 1-10 scale
  feedback        String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("WellnessEnrollmentCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("EmployeeWellnessEnrollments", fields: [employeeId], references: [id], onDelete: Cascade)
  program         WellnessProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  
  @@unique([programId, employeeId])
  @@index([companyId])
  @@index([employeeId])
  @@index([programId])
  @@index([active])
}
