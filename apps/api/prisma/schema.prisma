  approvedAt      DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  company         Company         @relation("BenefitEnrollmentCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation("EmployeeBenefitEnrollment", fields: [employeeId], references: [id], onDelete: Cascade)
  approver        Employee?       @relation("BenefitEnrollmentApprover", fields: [approvedBy], references: [id])
  
  @@unique([companyId, employeeId, benefitType, effectiveFrom])
  @@index([companyId])
  @@index([employeeId])
  @@index([benefitType])
  @@index([status])
  @@index([effectiveFrom])
