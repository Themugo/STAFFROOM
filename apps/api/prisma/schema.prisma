  attritionInterventions AttritionIntervention[] @relation("EmployeeAttritionInterventions")
  attritionRisksAsReviewer AttritionRisk[] @relation("EmployeeAttritionRisksAsReviewer")
  attritionInterventionsAsAssignedTo AttritionIntervention[] @relation("EmployeeAttritionInterventionsAsAssignedTo")
  
  // Phase 47: Burnout Detection Relations
  burnoutRisks BurnoutRisk[] @relation("EmployeeBurnoutRisks")
  wellnessEnrollments WellnessEnrollment[] @relation("EmployeeWellnessEnrollments")
  burnoutRisksAsReviewer BurnoutRisk[] @relation("EmployeeBurnoutRisksAsReviewer")
  
  @@index([employeeId])
  @@index([email])
  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([positionId])
}

model Department {
  id                String            @id @default(cuid())
  companyId         String
  branchId          String?
  
  name              String
  code              String?
  description       String?
  location          String?
  budget            Float?
  
  // Hierarchy fields
  parentDepartmentId String?
  level             Int               @default(0)
  path              String?           // For hierarchical queries
  
  // Management
  headId            String?           // Department head employee ID
  status            DepartmentStatus  @default(ACTIVE)
  
  // Settings
  settings          Json?             // Flexible settings for department-specific rules
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?           @relation(fields: [branchId], references: [id])
  parentDepartment  Department?       @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  subDepartments    Department[]      @relation("DepartmentHierarchy")
  head              Employee?         @relation("DepartmentHead", fields: [headId], references: [id])
  employees         Employee[]
  positions         Position[]
  workflows         DepartmentWorkflow[]
  policies          DepartmentPolicy[]
  
  // Workforce Intelligence Relations
  productivityScores DepartmentProductivityScore[]
  hiringForecasts    HiringForecast[]
  salaryBenchmarks  SalaryBenchmark[]
  
  // Asset Management Relations
  assets            Asset[]
  
  // Internal Communications Relations
  chats             Chat[]
  events            Event[]
  
  // Phase 20: Advanced Shift Management Relations
  shiftTemplates    ShiftTemplate[]
  
  // Phase 21: Duty Roster & Compensation Calendar Relations
  dutyRosters       DutyRoster[]
  
  // Phase 23: Workforce Balancing & Department Hub Relations
  workforceBalances WorkforceBalance[]
  departmentPosts   DepartmentPost[]
  
  // Phase 24: Shift Swap & Coverage Planning Relations
  shiftSwapRequests ShiftSwapRequest[]
  coverageWarnings  CoverageWarning[]
  calendarEvents    WorkforceCalendarEvent[]
  
  // Phase 25: Attendance Reconciliation & Workforce Planning Relations
  workforceForecasts WorkforceForecast[]
  
  // Phase 26: Governance Layer Architecture Relations
  auditableCommunications AuditableCommunication[]
  dataBreaches DataBreach[]
  
  // Phase 28: High Priority Gaps - Matrix Reporting Relations
  reportingRelationships ReportingRelationship[]
  clearanceItems ClearanceItem[]
  
  // Phase 29: Medium Priority Gaps - Workforce Planning Relations
  headcountRequests HeadcountRequest[]
  workforceBudgets WorkforceBudget[]
  
  // Phase 29: Succession Planning Relations
  successionPlans SuccessionPlan[]
  
  // Phase 29: Internal Mobility Relations
  mobilityRequestsAsCurrent MobilityRequest[] @relation("DepartmentMobilityRequestsAsCurrent")
  mobilityRequestsAsNew MobilityRequest[] @relation("DepartmentMobilityRequestsAsNew")
  
  // Phase 29: External Workforce Relations
  externalWorkers ExternalWorker[]
  
  // Phase 32: Benefits Eligibility Rules Relations
  benefitsEligibilityRules BenefitsEligibilityRule[]
  
  // Phase 40: Team Model Relations
  teams Team[] @relation("TeamDepartment")
  
  // Phase 42: Committee Tracking Relations
  committees Committee[] @relation("CommitteeDepartment")
  
  // Phase 43: Project-based Reporting Relations
  projects Project[] @relation("ProjectDepartment")
  
  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([parentDepartmentId])
  @@index([level])
  @@index([status])
}

model Position {
