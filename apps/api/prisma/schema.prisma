  updatedAt       DateTime            @updatedAt
  
  // Relations
  company         Company             @relation("PayrollReconciliationCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation("PayrollReconciliationEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  lockedByUser    Employee?           @relation("PayrollReconciliationLockedBy", fields: [lockedBy], references: [id], onDelete: SetNull)
  
  @@unique([companyId, employeeId, payrollPeriodId])
  @@index([companyId])
  @@index([employeeId])
  @@index([payrollPeriodId])
  @@index([status])
  @@index([locked])
}

// Dispute Resolution Center
model WorkforceDispute {
