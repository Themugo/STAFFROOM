  enabled         Boolean         @default(true)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([clientId])
  @@index([enabled])
}

model OAuthToken {
  id              String        @id @default(cuid())
  clientId        String
  userId          String?
  
  accessToken     String
  refreshToken    String?
  
  expiresAt       DateTime
  revokedAt       DateTime?
  
  scope           Json?
  
  createdAt       DateTime      @default(now())
  
  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
}

model ApiDocumentation {
  id              String                @id @default(cuid())
  
  path            String
  method          String
  description     String                @db.Text
  
  parameters      Json?
  requestBody     Json?
  responseBody    Json?
  
