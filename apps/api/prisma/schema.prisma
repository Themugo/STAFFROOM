// Phase 28: Discipline & Conduct
model DisciplinaryRecord {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Incident Details
  incidentDate    DateTime
  incidentDescription String
  incidentLocation String?
  
  // Disciplinary Action
  actionType      DisciplinaryActionType
  actionDate      DateTime
  
  // Warning Details
  warningLevel    Int?            // 1, 2, 3 for verbal, written, final
  warningExpiry   DateTime?
  
  // Description
  reason          String
  description     String?
  
  // Evidence
  evidence        Json?           // Documents, witness statements
  
  // Investigation
  investigationId String?
  investigationStatus InvestigationStatus @default(PENDING)
  
  // Hearing
  hearingId       String?
  hearingStatus   HearingStatus?
  hearingDate     DateTime?
  
  // Appeal
  appealId        String?
  appealStatus    AppealStatus?
  appealDate      DateTime?
  
  // Approval
  issuedBy        String
  approvedBy      String?
  approvedAt      DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  company         Company         @relation("DisciplinaryRecordCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation("EmployeeDisciplinaryRecord", fields: [employeeId], references: [id], onDelete: Cascade)
  issuer          Employee        @relation("DisciplinaryRecordIssuer", fields: [issuedBy], references: [id])
  approver        Employee?       @relation("DisciplinaryRecordApprover", fields: [approvedBy], references: [id])
  investigation   Investigation?
  hearing         DisciplinaryHearing?
  appeal          DisciplinaryAppeal?
  
  @@index([companyId])
  @@index([employeeId])
  @@index([actionDate])
  @@index([actionType])
