  workedHours     Float               @default(0)
  overtimeHours   Float               @default(0)
  compensationDays Int                @default(0)
  leaveTaken      Float               @default(0)
  payableHours    Float               @default(0)
  
  // Discrepancies
  discrepancies   Json?
  resolved        Boolean             @default(false)
  resolutionNotes String?
  
  // Lock status
