model Branch {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  code        String        // Branch code
  
  status      BranchStatus  @default(ACTIVE)
  
  address     Json?         // { street, city, state, country, postalCode }
  contactInfo Json?         // { phone, email }
  
  managerId   String?
  
  isHeadquarters Boolean    @default(false)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager     Employee?     @relation("BranchManager", fields: [managerId], references: [id])
  employees   Employee[]     @relation("BranchEmployees")
  departments Department[]
  
  // Asset Management Relations
  assets      Asset[]
  
  @@index([companyId])
  @@index([code])
  @@index([status])
}

model Location {
  id          String        @id @default(cuid())
  companyId   String
  branchId    String?
  
  name        String
  type        LocationType
  
  address     Json?         // { street, city, state, country, postalCode }
  
  coordinates Json?         // { latitude, longitude }
  
  capacity    Int?          // Maximum capacity
  isActive    Boolean       @default(true)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?       @relation(fields: [branchId], references: [id])
  
  @@index([companyId])
  @@index([branchId])
  @@index([type])
  @@index([isActive])
}

// Workforce Intelligence Models
model EmployeeRiskPrediction {
  id              String        @id @default(cuid())
  employeeId      String
  companyId       String
  
  predictionType  PredictionType
  riskLevel       RiskLevel
  riskScore       Float         // 0-100 score
  
  factors         Json?         // { tenure, salary, performance, attendance, etc. }
  recommendations Json?         // Actionable recommendations
  
  predictedDate   DateTime?     // When the risk is predicted to materialize
  confidence      Float         // Model confidence score (0-1)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([employeeId])
  @@index([companyId])
  @@index([predictionType])
  @@index([riskLevel])
  @@index([predictedDate])
}

model DepartmentProductivityScore {
  id              String        @id @default(cuid())
  departmentId    String
  companyId       String
  
  period          String        // "2024-Q1", "2024-01", etc.
  
  overallScore    Float         // 0-100 overall productivity score
  efficiencyScore Float         // Efficiency metrics
  qualityScore    Float         // Quality metrics
  collaborationScore Float      // Team collaboration metrics
  
  metrics         Json          // { tasksCompleted, onTimeDelivery, errorRate, etc. }
  benchmarks      Json?         // Industry benchmarks comparison
  trends          Json?         // Historical trends
  
  rank            Int?          // Department ranking within company
  percentile      Float?        // Percentile ranking
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@unique([departmentId, period])
  @@index([companyId])
  @@index([period])
  @@index([overallScore])
}

model HiringForecast {
  id              String        @id @default(cuid())
  companyId       String
  departmentId    String?
  
  forecastPeriod  ForecastPeriod
  forecastDate    DateTime      // Start of forecast period
  
  predictedHires Int           // Predicted number of hires
  confidence      Float         // Model confidence (0-1)
  
  breakdown       Json          // { byRole, byLevel, bySkill, etc. }
  drivers         Json?         // { attrition, growth, expansion, etc. }
  budgetImpact    Json?         // Estimated cost impact
  
  actualHires     Int?          // Actual hires (filled after period)
  accuracy        Float?        // Forecast accuracy (calculated after period)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([departmentId])
  @@index([forecastDate])
  @@index([forecastPeriod])
}

model SalaryBenchmark {
  id              String              @id @default(cuid())
  companyId       String
  
  category        BenchmarkCategory
  positionId      String?
  departmentId    String?
  
  marketAverage   Float               // Industry market average
  companyAverage  Float               // Company average
  percentile      Float               // Company percentile vs market
  
  region          String?             // Geographic region
  industry        String?             // Industry sector
  companySize     String?             // Company size tier
  
  dataPoints      Json                // { p25, p50, p75, p90, etc. }
  trends          Json?               // Historical salary trends
  recommendations Json?               // Compensation recommendations
  
  lastUpdated     DateTime            @default(now())
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  position        Position?           @relation(fields: [positionId], references: [id], onDelete: SetNull)
  department      Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  @@index([companyId])
  @@index([category])
  @@index([positionId])
  @@index([departmentId])
  @@index([lastUpdated])
}

// Performance Management Models
model Goal {
  id              String        @id @default(cuid())
  companyId       String
  parentGoalId    String?
  
  type            GoalType
  status          GoalStatus    @default(DRAFT)
  
  title           String
  description     String?
  
  period          String        // "2024-Q1", "2024-01", etc.
  startDate       DateTime
  endDate         DateTime
  
  weight          Float         @default(1.0) // Weight for parent goal calculation
  progress        Float         @default(0)   // 0-100 progress
  
  ownerId         String?       // Employee, Department, or Company owner
  ownerType       String?       // "EMPLOYEE", "DEPARTMENT", "COMPANY"
  
  alignment       Json?         // Alignment with company strategy
  metrics         Json?         // Custom metrics
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentGoal      Goal?         @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  subGoals        Goal[]        @relation("GoalHierarchy")
  keyResults      KeyResult[]
  feedbacks       Feedback[]
  
  @@index([companyId])
  @@index([parentGoalId])
  @@index([type])
  @@index([status])
  @@index([period])
  @@index([ownerId])
}

model KeyResult {
  id              String          @id @default(cuid())
  goalId          String
  
  type            KeyResultType
  status          KeyResultStatus @default(NOT_STARTED)
  
  title           String
  description     String?
  
  targetValue     Float?
  currentValue    Float?         @default(0)
  unit            String?         // "%", "count", "hours", etc.
  
  startDate       DateTime
  dueDate         DateTime
  
  weight          Float           @default(1.0) // Weight for goal calculation
  confidence      Float?          // Confidence in achieving this KR
  
  progress        Float           @default(0) // 0-100 calculated progress
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  goal            Goal            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  @@index([goalId])
  @@index([type])
  @@index([status])
  @@index([dueDate])
}

model Feedback {
  id              String          @id @default(cuid())
  companyId       String
  goalId          String?
  
  fromEmployeeId  String
  toEmployeeId    String
  
  type            FeedbackType
  direction       FeedbackDirection
  
  subject         String
  content         String          @db.Text
  
  rating          Int?            // 1-5 rating
  tags            Json?           // ["leadership", "communication", etc.]
  
  isAnonymous     Boolean         @default(false)
  isPublic        Boolean         @default(false)
  
  acknowledged    Boolean         @default(false)
  acknowledgedAt  DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  goal            Goal?           @relation(fields: [goalId], references: [id], onDelete: SetNull)
  fromEmployee    Employee        @relation("FeedbackGiven", fields: [fromEmployeeId], references: [id], onDelete: Cascade)
  toEmployee      Employee        @relation("FeedbackReceived", fields: [toEmployeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([goalId])
  @@index([fromEmployeeId])
  @@index([toEmployeeId])
  @@index([type])
  @@index([createdAt])
}

model Appraisal {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  reviewCycleId   String?
  
  status          AppraisalStatus @default(DRAFT)
  
  period          String          // "2024-Q1", "2024-01", etc.
  startDate       DateTime
  endDate         DateTime
  
  selfRating      Int?            // 1-5 self rating
  managerRating   Int?            // 1-5 manager rating
  finalRating     Int?            // 1-5 final rating
  
  strengths       Json?           // Array of strengths
  improvements    Json?           // Array of improvement areas
  achievements    Json?           // Key achievements
  goals           Json?           // Goals for next period
  
  comments        Json?           // Comments from different stages
  
  approvedBy      String?         // Manager who approved
  approvedAt      DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewCycle     ReviewCycle?    @relation(fields: [reviewCycleId], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([reviewCycleId])
  @@index([status])
  @@index([period])
}

model ReviewCycle {
  id              String          @id @default(cuid())
  companyId       String
  
  name            String
  description     String?
  type            String          // "360", "SELF", "MANAGER", "PEER"
  
  period          String          // "2024-Q1", "2024-01", etc.
  startDate       DateTime
  endDate         DateTime
  
  status          String          @default("DRAFT") // DRAFT, ACTIVE, COMPLETED
  
  participants    Json?           // Employee IDs participating
  reviewers       Json?           // Reviewer assignments
  
  template        Json?           // Review template/questions
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appraisals      Appraisal[]
  responses       ReviewResponse[]
  
  @@index([companyId])
  @@index([period])
  @@index([status])
}

model ReviewResponse {
  id              String          @id @default(cuid())
  reviewCycleId   String
  reviewerId      String
  subjectId       String          // Employee being reviewed
  
  answers         Json            // Question answers
  rating          Int?            // Overall rating
  comments        String?         @db.Text
  
  submitted       Boolean         @default(false)
  submittedAt     DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  reviewCycle     ReviewCycle     @relation(fields: [reviewCycleId], references: [id], onDelete: Cascade)
  
  @@index([reviewCycleId])
  @@index([reviewerId])
  @@index([subjectId])
  @@index([submitted])
}

model PromotionRecommendation {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  
  status          PromotionStatus @default(RECOMMENDED)
  
  currentPosition String
  recommendedPosition String
  recommendedLevel String?
  
  effectiveDate   DateTime?
  
  justification   String          @db.Text
  achievements    Json?           // Key achievements supporting promotion
  skills          Json?           // Skills demonstrated
  performance     Json?           // Performance metrics
  
  salaryIncrease  Json?           // { current, recommended, percentage }
  benefits        Json?           // Additional benefits
  
  recommendedBy   String          // Manager recommending
  reviewedBy      String?         // HR reviewer
  approvedBy      String?         // Final approver
  
  reviewedAt      DateTime?
  approvedAt      DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([effectiveDate])
}

// Learning & Development Models
model Course {
  id              String        @id @default(cuid())
  companyId       String
  
  type            CourseType
  status          CourseStatus  @default(DRAFT)
  
  title           String
  description     String        @db.Text
  category        String?
  tags            Json?         // ["leadership", "technical", etc.]
  
  duration        Int?          // Duration in minutes
  difficulty      String?       // BEGINNER, INTERMEDIATE, ADVANCED
  
  instructorId    String?
  prerequisites   Json?         // Array of course IDs
  
  thumbnail       String?
  materials       Json?         // Course materials/links
  
  publishedAt     DateTime?
  expiresAfter    Int?          // Days after enrollment when course expires
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  instructor      Employee?     @relation("CourseInstructor", fields: [instructorId], references: [id])
  modules         CourseModule[]
  enrollments     Enrollment[]
  learningPaths   LearningPathCourse[]
  assessments     Assessment[] @relation("CourseAssessment")
  
  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([category])
  @@index([instructorId])
}

model CourseModule {
  id              String        @id @default(cuid())
  courseId        String
  
  title           String
  description     String?
  content         String        @db.Text
  order           Int
  
  duration        Int?          // Duration in minutes
  materials       Json?         // Module materials/links
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons         Lesson[]
  
  @@index([courseId])
  @@index([order])
}

model Lesson {
  id              String        @id @default(cuid())
  moduleId        String
  
  title           String
  content         String        @db.Text
  order           Int
  
  duration        Int?          // Duration in minutes
  videoUrl        String?
  materials       Json?         // Lesson materials/links
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  module          CourseModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress        LessonProgress[]
  
  @@index([moduleId])
  @@index([order])
}

model Enrollment {
  id              String          @id @default(cuid())
  courseId        String
  employeeId      String
  
  status          EnrollmentStatus @default(ENROLLED)
  
  enrolledAt      DateTime        @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  
  progress        Float           @default(0) // 0-100
  score           Float?          // Final score if applicable
  
  certificateUrl  String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([courseId, employeeId])
  @@index([courseId])
  @@index([employeeId])
  @@index([status])
  @@index([completedAt])
}

model LessonProgress {
  id              String        @id @default(cuid())
  lessonId        String
  employeeId      String
  
  completed       Boolean       @default(false)
  completedAt     DateTime?
  
  timeSpent       Int?          // Time spent in seconds
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  lesson          Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([lessonId, employeeId])
  @@index([lessonId])
  @@index([employeeId])
}

model LearningPath {
  id              String          @id @default(cuid())
  companyId       String
  
  type            LearningPathType
  name            String
  description     String?
  
  targetRole      String?        // For role-based paths
  targetSkills    Json?          // For skill-based paths
  targetDepartment String?       // For department-based paths
  
  duration        Int?          // Estimated duration in days
  isMandatory     Boolean        @default(false)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  courses         LearningPathCourse[]
  enrollments     LearningPathEnrollment[]
  
  @@index([companyId])
  @@index([type])
  @@index([targetRole])
  @@index([targetDepartment])
}

model LearningPathCourse {
  id              String        @id @default(cuid())
  learningPathId  String
  courseId        String
  
  order           Int
  isMandatory     Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  
  learningPath    LearningPath  @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([learningPathId, courseId])
  @@index([learningPathId])
  @@index([courseId])
}

model LearningPathEnrollment {
  id              String          @id @default(cuid())
  learningPathId  String
  employeeId      String
  
  status          EnrollmentStatus @default(ENROLLED)
  
  enrolledAt      DateTime        @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  
  progress        Float           @default(0) // 0-100
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  learningPath    LearningPath    @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  
  @@unique([learningPathId, employeeId])
  @@index([learningPathId])
  @@index([employeeId])
  @@index([status])
}

model Certification {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  courseId        String?
  
  name            String
  description     String?
  issuingBody     String?
  
  credentialId    String?             // External credential ID
  certificateUrl  String?
  
  status          CertificationStatus @default(ACTIVE)
  issuedDate      DateTime
  expiryDate      DateTime?
  
  skills          Json?               // Skills certified
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  course          Course?             @relation(fields: [courseId], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([courseId])
  @@index([status])
  @@index([expiryDate])
}

model AssessmentAttempt {
  id              String        @id @default(cuid())
  assessmentId    String
  employeeId      String
  
  attemptNumber   Int
  score           Float
  passed          Boolean
  
  answers         Json          // Student answers
  startedAt       DateTime
  completedAt     DateTime?
  timeSpent       Int?          // Time spent in seconds
  
  createdAt       DateTime      @default(now())
  
  assessment      Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  
  @@index([assessmentId])
  @@index([employeeId])
  @@index([passed])
}

model Skill {
  id              String        @id @default(cuid())
  companyId       String
  
  name            String
  category        String?
  description     String?
  
  proficiency     Json?         // Proficiency levels
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeSkills  EmployeeSkill[]
  
  @@index([companyId])
  @@index([category])
}

model EmployeeSkill {
  id              String        @id @default(cuid())
  employeeId      String
  skillId         String
  
  level           String        // BEGINNER, INTERMEDIATE, ADVANCED, EXPERT
  yearsExperience Int?
  
  certified       Boolean       @default(false)
  certifiedAt     DateTime?
  
  source          String?       // Where skill was acquired (course, experience, etc.)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skill           Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, skillId])
  @@index([employeeId])
  @@index([skillId])
  @@index([level])
}

// Asset Management Models
model Asset {
  id              String        @id @default(cuid())
  companyId       String
  branchId        String?
  
  type            AssetType
  status          AssetStatus   @default(AVAILABLE)
  
  name            String
  description     String?
  serialNumber    String?       @unique
  assetTag        String?       @unique
  barcode         String?
  
  brand           String?
  model           String?
  year            Int?
  color           String?
  
  purchaseDate    DateTime?
  purchaseCost    Float?
  currentValue    Float?
  
  location        String?
  departmentId    String?
  
  specifications  Json?         // Technical specifications
  accessories     Json?         // Included accessories
  
  warrantyExpiry  DateTime?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  
  imageUrl        String?
  notes           String?       @db.Text
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch?       @relation(fields: [branchId], references: [id])
  department      Department?   @relation(fields: [departmentId], references: [id])
  assignments     AssetAssignment[]
  audits          AssetAudit[]
  
  @@index([companyId])
  @@index([branchId])
  @@index([type])
  @@index([status])
  @@index([serialNumber])
  @@index([assetTag])
  @@index([departmentId])
}

model AssetAssignment {
  id              String            @id @default(cuid())
  assetId         String
  employeeId      String
  companyId       String
  
  status          AssignmentStatus  @default(ACTIVE)
  
  assignedAt      DateTime          @default(now())
  assignedBy      String            // Employee who assigned
  expectedReturn  DateTime?
  returnedAt      DateTime?
  returnedBy      String?           // Employee who received return
  
  conditionOnAssignment Json?     // Condition notes when assigned
  conditionOnReturn    Json?     // Condition notes when returned
  
  notes           String?           @db.Text
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee        Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([assetId])
  @@index([employeeId])
  @@index([companyId])
  @@index([status])
  @@index([assignedAt])
  @@index([expectedReturn])
}

model AssetAudit {
  id              String        @id @default(cuid())
  assetId         String
  companyId       String
  auditorId       String
  
  status          AuditStatus   @default(SCHEDULED)
  
  scheduledDate   DateTime
  completedDate   DateTime?
  
  condition       Json?         // Audit findings
  issues          Json?         // Issues found
  recommendations Json?         // Recommendations
  photos          Json?         // Photo URLs
  
  notes           String?       @db.Text
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([assetId])
  @@index([companyId])
  @@index([auditorId])
  @@index([status])
  @@index([scheduledDate])
}

// Internal Communications Models
model Announcement {
  id              String                @id @default(cuid())
  companyId       String
  
  type            AnnouncementType
  priority        AnnouncementPriority @default(MEDIUM)
  
  title           String
  content         String               @db.Text
  imageUrl        String?
  
  targetAudience  Json?                 // ["ALL", "DEPARTMENT:123", "ROLE:MANAGER"]
  
  publishedAt     DateTime?
  expiresAt       DateTime?
  
  authorId        String
  
  attachments     Json?                 // File URLs
  tags            Json?                 // ["urgent", "policy", etc.]
  
  viewCount       Int                  @default(0)
  
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author          Employee              @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  reads           AnnouncementRead[]
  
  @@index([companyId])
  @@index([type])
  @@index([priority])
  @@index([publishedAt])
  @@index([expiresAt])
}

model AnnouncementRead {
  id              String        @id @default(cuid())
  announcementId  String
  employeeId      String
  
  readAt          DateTime      @default(now())
  
  announcement    Announcement  @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  
  @@unique([announcementId, employeeId])
  @@index([announcementId])
  @@index([employeeId])
}

model Chat {
  id              String        @id @default(cuid())
  companyId       String
  
  type            ChatType
  status          ChatStatus    @default(ACTIVE)
  
  name            String?
  description     String?
  
  createdBy       String
  
  departmentId    String?
  isPublic        Boolean       @default(false)
  
  imageUrl        String?
  
  lastMessageAt   DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator         Employee      @relation("ChatCreator", fields: [createdBy], references: [id])
  department      Department?   @relation(fields: [departmentId], references: [id])
  participants    ChatParticipant[]
  messages        ChatMessage[]
  
  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([departmentId])
  @@index([lastMessageAt])
}

model ChatParticipant {
  id              String        @id @default(cuid())
  chatId          String
  employeeId      String
  
  joinedAt        DateTime      @default(now())
  lastReadAt      DateTime?
  
  chat            Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  @@unique([chatId, employeeId])
  @@index([chatId])
  @@index([employeeId])
}

model ChatMessage {
  id              String        @id @default(cuid())
  chatId          String
  senderId        String
  
  content         String       @db.Text
  type            String        @default("TEXT") // TEXT, IMAGE, FILE, EMOJI
  
  replyToId       String?
  
  isEdited        Boolean       @default(false)
  editedAt        DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  chat            Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender          Employee      @relation("ChatMessageSender", fields: [senderId], references: [id])
  replyTo         ChatMessage?  @relation("MessageReply", fields: [replyToId], references: [id])
  replies         ChatMessage[]  @relation("MessageReply")
  
  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

model Event {
  id              String        @id @default(cuid())
  companyId       String
  
  type            EventType
  status          EventStatus   @default(DRAFT)
  
  title           String
  description     String        @db.Text
  imageUrl        String?
  
  startDate       DateTime
  endDate         DateTime
  
  location        String?
  isVirtual       Boolean       @default(false)
  virtualLink     String?
  
  maxCapacity     Int?
  departmentId    String?
  
  organizerId     String
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?   @relation(fields: [departmentId], references: [id])
  organizer       Employee      @relation("EventOrganizer", fields: [organizerId], references: [id])
  registrations   EventRegistration[]
  
  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([startDate])
  @@index([departmentId])
}

model EventRegistration {
  id              String        @id @default(cuid())
  eventId         String
  employeeId      String
  
  registeredAt    DateTime      @default(now())
  attended        Boolean       @default(false)
  
  notes           String?       @db.Text
  
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@unique([eventId, employeeId])
  @@index([eventId])
  @@index([employeeId])
}

model Survey {
  id              String        @id @default(cuid())
  companyId       String
  
  type            SurveyType
  status          SurveyStatus  @default(DRAFT)
  
  title           String
  description     String        @db.Text
  
  startDate       DateTime
  endDate         DateTime
  
  anonymous       Boolean       @default(false)
  allowMultiple   Boolean       @default(false)
  
  questions       Json          // Survey questions
  targetAudience  Json?         // ["ALL", "DEPARTMENT:123", "ROLE:MANAGER"]
  
  createdBy       String
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator         Employee      @relation("SurveyCreator", fields: [createdBy], references: [id])
  responses       SurveyResponse[]
  
  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model SurveyResponse {
  id              String        @id @default(cuid())
  surveyId        String
  employeeId      String?
  
  answers         Json          // Survey answers
  submittedAt     DateTime      @default(now())
  
  survey          Survey        @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  
  @@index([surveyId])
  @@index([employeeId])
  @@index([submittedAt])
}

model Recognition {
  id              String        @id @default(cuid())
  companyId       String
  
  type            RecognitionType
  
  title           String
  description     String        @db.Text
  
  recipientId     String
  giverId         String
  
  imageUrl        String?
  
  likes           Int           @default(0)
  
  tags            Json?         // ["#teamwork", "#leadership"]
  
  createdAt       DateTime      @default(now())
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recipient       Employee      @relation("RecognitionRecipient", fields: [recipientId], references: [id])
  giver           Employee      @relation("RecognitionGiver", fields: [giverId], references: [id])
  
  @@index([companyId])
  @@index([type])
  @@index([recipientId])
  @@index([giverId])
  @@index([createdAt])
}

// Enterprise Integrations Models
model Integration {
  id              String            @id @default(cuid())
  companyId       String
  
  type            IntegrationType
  status          IntegrationStatus @default(PENDING)
  
  name            String
  description     String?
  
  apiKey          String?
  apiSecret       String?
  
  config          Json?             // Integration-specific configuration
  settings        Json?             // Integration settings
  
  lastSyncAt      DateTime?
  lastError       String?
  lastErrorAt     DateTime?
  
  enabled         Boolean           @default(true)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  webhooks        Webhook[]
  
  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([enabled])
}

model Webhook {
  id              String        @id @default(cuid())
  companyId       String
  integrationId   String?
  
  name            String
  description     String?
  
  url             String
  method          String        @default("POST")
  headers         Json?
  
  status          WebhookStatus @default(ACTIVE)
  
  events          Json?         // Event types to trigger webhook
  
  lastTriggeredAt DateTime?
  lastError       String?
  lastErrorAt     DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration     Integration? @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  logs            WebhookLog[]
  
  @@index([companyId])
  @@index([integrationId])
  @@index([status])
}

model WebhookLog {
  id              String        @id @default(cuid())
  webhookId       String
  
  payload         Json
  response        Json?
  statusCode      Int?
  
  success         Boolean
  error           String?
  
  executedAt      DateTime      @default(now())
  
  webhook         Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  @@index([webhookId])
  @@index([executedAt])
}

// Regional Compliance Models
model ComplianceRule {
  id              String          @id @default(cuid())
  
  country         CountryCode
  type            ComplianceType
  
  name            String
  description     String          @db.Text
  
  rules           Json            // Compliance rules as JSON
  effectiveDate   DateTime
  expiryDate      DateTime?
  
  isActive        Boolean         @default(true)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  companyCompliances CompanyCompliance[]
  
  @@index([country])
  @@index([type])
  @@index([isActive])
  @@index([effectiveDate])
}

model CompanyCompliance {
  id              String          @id @default(cuid())
  companyId       String
  complianceRuleId String
  
  isEnabled       Boolean         @default(true)
  
  customRules     Json?           // Company-specific overrides
  
  lastReviewedAt  DateTime?
  nextReviewDate  DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  complianceRule  ComplianceRule  @relation(fields: [complianceRuleId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, complianceRuleId])
  @@index([companyId])
  @@index([complianceRuleId])
  @@index([isEnabled])
}

// Enterprise SaaS Architecture Models
model WhiteLabelConfig {
  id              String        @id @default(cuid())
  companyId       String
  
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String?
  secondaryColor  String?
  
  customDomain    String?
  customEmail     String?
  
  brandingName    String?
  brandingTagline String?
  
  cssOverrides    Json?
  customScripts   Json?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@unique([companyId])
