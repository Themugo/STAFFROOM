  category        String          // ATTENDANCE, LEAVE, PAYROLL, PERFORMANCE, etc.
  
  enabled         Boolean         @default(true)
  
  conditions      Json            // Rule conditions
  actions         Json            // Rule actions
  
  priority        Int             @default(0)
  
  triggeredCount  Int             @default(0)
  lastTriggered   DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
  @@index([category])
  @@index([enabled])
  @@index([priority])
}

model RuleExecutionLog {
  id              String        @id @default(cuid())
  ruleId          String
  
  matched         Boolean
  context         Json          // Execution context
  results         Json?         // Execution results
  
  executedAt      DateTime      @default(now())
  
  @@index([ruleId])
  @@index([executedAt])
}

model OAuthClient {
  id              String          @id @default(cuid())
  companyId       String
  
  name            String
  description     String?
  
  clientId        String          @unique
  clientSecret    String
  
  redirectUris    Json            // Array of redirect URIs
  grantTypes      Json            // Array of grant types
