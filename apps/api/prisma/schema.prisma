  connections     WorkflowConnection[] @relation("NodeConnections")
  
  @@index([workflowId])
  @@index([type])
}

model WorkflowConnection {
  id              String        @id @default(cuid())
  workflowId      String
  
  fromNodeId      String
  toNodeId        String
  
  condition       Json?         // Connection condition
  
  createdAt       DateTime      @default(now())
  
  workflow        WorkflowTemplate      @relation("WorkflowNodes", fields: [workflowId], references: [id], onDelete: Cascade)
  fromNode        WorkflowNode  @relation("NodeConnectionsFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode          WorkflowNode  @relation("NodeConnectionsTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  
  @@index([workflowId])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model BusinessRule {
  id              String          @id @default(cuid())
