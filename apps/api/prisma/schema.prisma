// Phase 28: High Priority Gaps - Employment Types & Contract Governance
model EmploymentContract {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Contract Details
  contractType    ContractType
  employmentType  EmploymentType
  status          ContractStatus  @default(ACTIVE)
  
  // Contract Period
  startDate       DateTime
  endDate         DateTime?
  autoRenew       Boolean         @default(false)
  renewalDays     Int?            // Days before expiry to auto-renew
  
  // Probation
  probationStatus ProbationStatus @default(NOT_APPLICABLE)
  probationStart  DateTime?
  probationEnd    DateTime?
  probationDays   Int?
  
  // Terms
  salary          Float
  salaryCurrency  String          @default("USD")
  workHours       Float?          // Weekly hours
  workLocation    String?
  
  // Acting Appointment
  isActing        Boolean         @default(false)
  actingFor       String?         // Position ID
  actingStart     DateTime?
  actingEnd       DateTime?
  
  // Metadata
  contractFile    String?         // File URL
  notes           String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  company         Company         @relation("EmploymentContractCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation("EmployeeContract", fields: [employeeId], references: [id], onDelete: Cascade)
  amendments      ContractAmendment[]
  
  @@unique([companyId, employeeId, status])
  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model ContractAmendment {
  id              String          @id @default(cuid())
  companyId       String
  contractId      String
  employeeId      String
  
  // Amendment Details
  amendmentType   AmendmentType
  effectiveDate   DateTime
  
  // Changes
  oldSalary       Float?
  newSalary       Float?
  oldEndDate      DateTime?
  newEndDate      DateTime?
  oldPositionId   String?
  newPositionId   String?
  oldHours        Float?
  newHours        Float?
  oldLocation     String?
  newLocation     String?
  
  // Reason
  reason          String
  description     String?
  
  // Approval
  approvedBy      String?
  approvedAt      DateTime?
  
  createdAt       DateTime        @default(now())
  
  // Relations
  company         Company         @relation("ContractAmendmentCompany", fields: [companyId], references: [id], onDelete: Cascade)
  contract        EmploymentContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  employee        Employee        @relation("EmployeeContractAmendment", fields: [employeeId], references: [id], onDelete: Cascade)
  approver        Employee?       @relation("ContractAmendmentApprover", fields: [approvedBy], references: [id])
  
  @@index([companyId])
  @@index([contractId])
  @@index([employeeId])
  @@index([effectiveDate])
}

// Phase 28: Compensation & Benefits
model CompensationComponent {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Component Details
  componentType   CompensationType
  allowanceType   AllowanceType?
  bonusType       BonusType?
  commissionType  CommissionType?
  
  // Amount
  amount          Float
  currency        String          @default("USD")
  
  // Calculation
  isPercentage    Boolean         @default(false)
  percentageOf    String?         // Base salary or other component
  isRecurring     Boolean         @default(true)
  frequency       String?         // MONTHLY, QUARTERLY, YEARLY, ONE_TIME
  
  // Period
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  
  // Conditions
  conditions      Json?           // KPI targets, sales targets, etc.
  
  // Approval
  approvedBy      String?
  approvedAt      DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  company         Company         @relation("CompensationComponentCompany", fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation("EmployeeCompensationComponent", fields: [employeeId], references: [id], onDelete: Cascade)
  approver        Employee?       @relation("CompensationComponentApprover", fields: [approvedBy], references: [id])
  
  @@index([companyId])
  @@index([employeeId])
  @@index([componentType])
  @@index([effectiveFrom])
}

model BenefitEnrollment {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  
  // Benefit Details
  benefitType     BenefitType
  status          BenefitStatus   @default(PENDING_ENROLLMENT)
  enrollmentStatus EnrollmentStatus @default(ENROLLED)
  
  // Coverage
  coverageType    String?         // INDIVIDUAL, FAMILY, SPOUSE, CHILDREN
  coverageAmount  Float?
  currency        String          @default("USD")
  
  // Cost
