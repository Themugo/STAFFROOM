  @@index([periodStart])
}

// Phase 19: Advanced Platform Features Models
model WorkflowNode {
  id              String          @id @default(cuid())
  workflowId      String
  
  type            WorkflowNodeType
  name            String
  description     String?
  
  positionX       Int
  positionY       Int
  
