{
  "name": "OnboardingChecklist",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string"
    },
    "employee_name": {
      "type": "string"
    },
    "department": {
      "type": "string"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "done": {
            "type": "boolean"
          },
          "due_date": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "In Progress",
        "Completed",
        "Not Started"
      ],
      "default": "Not Started"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "employee_id",
    "employee_name"
  ]
}