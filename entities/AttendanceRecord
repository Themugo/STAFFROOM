{
  "name": "AttendanceRecord",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string"
    },
    "employee_name": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "check_in": {
      "type": "string",
      "description": "Check-in time e.g. 09:00"
    },
    "check_out": {
      "type": "string",
      "description": "Check-out time e.g. 17:30"
    },
    "status": {
      "type": "string",
      "enum": [
        "Present",
        "Absent",
        "Late",
        "Half Day",
        "Remote"
      ],
      "default": "Present"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "employee_id",
    "date"
  ]
}